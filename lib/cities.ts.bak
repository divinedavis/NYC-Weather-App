      { name: 'Kitsilano', slug: 'kitsilano', lat: 49.2635, lon: -123.1640, group: 'West', description: "Kitsilano's south-facing beach on English Bay receives the most direct afternoon sun of any Vancouver neighborhood, making it the city's warmest beach area in summer." },
      { name: 'North Vancouver', slug: 'north-vancouver', lat: 49.3253, lon: -123.0688, group: 'North Shore', description: "North Vancouver on the slopes of the North Shore Mountains receives significantly more rainfall than the downtown peninsula — the mountains force Pacific moisture to rise and precipitate. Orographic precipitation is 30-50% higher here." },
