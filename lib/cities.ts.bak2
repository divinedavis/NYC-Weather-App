      { name: 'Latin Quarter', slug: 'latin-quarter', lat: 48.8497, lon: 2.3483, group: 'Left Bank', description: "The Latin Quarter's dense student neighborhood sits on gentle elevation with Luxembourg Gardens to the west providing a welcome temperature buffer in summer." },
      { name: 'Pigalle', slug: 'pigalle', lat: 48.8836, lon: 2.3385, group: 'North Paris', description: "Pigalle sits at the foot of Montmartre hill where cold air from the heights drains downward on calm clear nights, creating a slight temperature inversion." },
      { name: 'Opéra', slug: 'opera', lat: 48.8717, lon: 2.3316, group: 'Right Bank', description: "The Grands Boulevards around the Opéra are wide and wind-exposed. The dense commercial character retains heat, but large intersections allow some ventilation." },
      { name: 'République', slug: 'republique', lat: 48.8675, lon: 2.3634, group: 'Right Bank', description: "Place de la République's large open square is one of Paris's most wind-exposed public spaces — the wide plaza amplifies breezes regardless of direction." },
      { name: 'Nation', slug: 'nation', lat: 48.8482, lon: 2.3960, group: 'East Paris', description: "Nation's large circular plaza in eastern Paris channels winds from multiple avenues. The Vincennes woods to the east provide cooling air flow in summer evenings." },
      { name: 'Canal Saint-Martin', slug: 'canal-saint-martin', lat: 48.8712, lon: 2.3625, group: 'Right Bank', description: "The Canal Saint-Martin's tree-lined banks create a cooling evaporative corridor through northeastern Paris, noticeably fresher than adjacent inland streets." },
      { name: 'Châtelet', slug: 'chatelet', lat: 48.8589, lon: 2.3469, group: 'Central Paris', description: "Châtelet-Les Halles at Paris's geographic center is surrounded by dense Haussmann blocks that amplify summer heat. The underground complex adds thermal mass." },
      { name: 'Bercy', slug: 'bercy', lat: 48.8392, lon: 2.3823, group: 'South East Paris', description: "Bercy Park along the Seine in eastern Paris creates a riverside green corridor with good ventilation and a cooler microclimate than surrounding dense blocks." },
      { name: 'Batignolles', slug: 'batignolles', lat: 48.8847, lon: 2.3238, group: 'North West Paris', description: "The Batignolles neighborhood and its park in northwest Paris offer a village-like respite with enough tree coverage to buffer the urban heat island." },
      { name: 'Buttes-Chaumont', slug: 'buttes-chaumont', lat: 48.8800, lon: 2.3819, group: 'North East Paris', description: "Buttes-Chaumont Park's dramatic hills create one of northeast Paris's coolest microclimates, with lake-generated humidity and shade from dense mature trees." },
      { name: 'Oberkampf', slug: 'oberkampf', lat: 48.8635, lon: 2.3749, group: 'East Paris', description: "Oberkampf's lively eastern neighborhood sits on flat terrain between canals and parks, with typical Haussmann block heat retention in summer." },
      { name: 'Boulogne', slug: 'boulogne', lat: 48.8352, lon: 2.2397, group: 'West Paris', description: "Adjacent to the vast Bois de Boulogne, this western suburb benefits enormously from the forest's cooling effect — among the freshest summer microclimates in greater Paris." },
      { name: 'Vincennes', slug: 'vincennes', lat: 48.8479, lon: 2.4388, group: 'East Paris', description: "Vincennes borders the Bois de Vincennes, Paris's eastern forest, which keeps local temperatures several degrees lower than the city center on hot summer days." },
      { name: 'Saint-Denis', slug: 'saint-denis', lat: 48.9362, lon: 2.3574, group: 'North Paris', description: "Saint-Denis north of Paris experiences more extreme weather than the sheltered city center — stronger winds, harder frosts in winter, and more heat in summer without Haussmann density buffering." },
    ],
  },
  {
    name: 'Dubai',
    slug: 'dubai',
    country: 'United Arab Emirates',
    flag: '🇦🇪',
    lat: 25.2048,
    lon: 55.2708,
    timezone: 'Asia/Dubai',
    description: "Dubai has a hot desert climate with virtually no rainfall and searing summers where temperatures routinely exceed 40°C (104°F) with intense humidity from the Persian Gulf. The Gulf moderates winter temperatures and brings morning sea fog. Summer heat is compounded by the urban heat island in dense downtown areas, while coastal neighborhoods benefit from sea breezes that can make outdoor conditions more bearable. Shamal winds from the north bring sandstorms and dust haze spring through summer.",
    districts: [
      { name: 'Downtown Dubai', slug: 'downtown-dubai', lat: 25.1972, lon: 55.2744, group: 'Central Dubai', description: "The Burj Khalifa creates powerful updrafts and wind shear at high altitude. At street level, the dense skyscraper cluster traps heat, making Downtown Dubai among the UAE's most extreme urban heat islands." },
      { name: 'Dubai Marina', slug: 'dubai-marina', lat: 25.0805, lon: 55.1403, group: 'West Dubai', description: "Dubai Marina's water channel running through the development provides evaporative cooling and sea breezes from the Gulf just minutes away, making it more livable than inland neighborhoods in summer." },
      { name: 'Jumeirah', slug: 'jumeirah', lat: 25.2048, lon: 55.2708, group: 'Coastal Dubai', description: "Jumeirah's beachfront position on the Gulf ensures consistent sea breezes that significantly reduce the apparent heat compared to inland neighborhoods." },
      { name: 'Palm Jumeirah', slug: 'palm-jumeirah', lat: 25.1124, lon: 55.1390, group: 'Coastal Dubai', description: "The Palm peninsula is surrounded by Gulf waters on all sides, bringing sea breezes from every direction that help offset the intense solar radiation." },
      { name: 'Business Bay', slug: 'business-bay', lat: 25.1870, lon: 55.2635, group: 'Central Dubai', description: "Business Bay's Dubai Canal provides some water-adjacent cooling but the dense commercial towers create significant heat retention and wind tunnel effects." },
      { name: 'Deira', slug: 'deira', lat: 25.2697, lon: 55.3094, group: 'Old Dubai', description: "Historic Deira on the Dubai Creek has lower building heights than downtown, with the Creek providing some evaporative cooling and traditional wind tower (barjeel) architecture designed to catch breezes." },
      { name: 'DIFC', slug: 'difc', lat: 25.2138, lon: 55.2800, group: 'Central Dubai', description: "The Dubai International Financial Centre's glass tower cluster creates intense heat reflection and wind shear. The elevated indoor walkways somewhat insulate pedestrians from outdoor extremes." },
      { name: 'JBR', slug: 'jbr', lat: 25.0762, lon: 55.1317, group: 'West Dubai', description: "Jumeirah Beach Residence's open beachfront and Gulf breezes make it one of Dubai's most pleasant outdoor districts in winter and transition seasons." },
      { name: 'Bur Dubai', slug: 'bur-dubai', lat: 25.2543, lon: 55.2967, group: 'Old Dubai', description: "Historic Bur Dubai's traditional low-rise buildings along the Creek were designed with passive cooling in mind. The Creek provides evaporative cooling and wind funneling." },
      { name: 'Karama', slug: 'karama', lat: 25.2314, lon: 55.3067, group: 'Central Dubai', description: "Karama's dense mid-rise residential blocks retain intense heat with limited green space and minimal sea breeze penetration this far inland." },
      { name: 'Internet City', slug: 'internet-city', lat: 25.0964, lon: 55.1575, group: 'West Dubai', description: "Dubai Internet City's campus-style development near the Gulf benefits from sea breezes and slightly more open planning than the downtown core." },
      { name: 'Media City', slug: 'media-city', lat: 25.1027, lon: 55.1676, group: 'West Dubai', description: "Adjacent to Internet City, Media City's open campus layout near the coast allows Gulf breezes to penetrate and moderate summer heat." },
      { name: 'Al Quoz', slug: 'al-quoz', lat: 25.1502, lon: 55.2255, group: 'Central Dubai', description: "Al Quoz's industrial and arts district in central Dubai has minimal tree cover and high thermal mass from warehouses, creating intense heat retention." },
      { name: 'Dubai Creek', slug: 'dubai-creek', lat: 25.2631, lon: 55.3006, group: 'Old Dubai', description: "The historic Dubai Creek waterway provides evaporative cooling along its banks, making waterfront dining and walking more comfortable than inland streets." },
      { name: 'Mirdif', slug: 'mirdif', lat: 25.2264, lon: 55.4147, group: 'East Dubai', description: "Mirdif's suburban residential character in eastern Dubai, distant from the Gulf, means hotter and more arid conditions with minimal sea breeze influence." },
    ],
  },
  {
    name: 'Sydney',
    slug: 'sydney',
    country: 'Australia',
    flag: '🇦🇺',
    lat: -33.8688,
    lon: 151.2093,
    timezone: 'Australia/Sydney',
    description: "Sydney enjoys a temperate oceanic climate with warm summers, mild winters, and rainfall throughout the year. Sydney Harbour and the Pacific Ocean create significant coastal influence — sea breezes (locally called the 'Southerly Buster') arrive in summer afternoons and dramatically cool the city within minutes. Western suburbs are 5–10°C hotter in summer than coastal areas, and extreme fire weather during inland heat waves creates dangerous conditions.",
    districts: [
      { name: 'CBD', slug: 'cbd', lat: -33.8688, lon: 151.2093, group: 'Inner Sydney', description: "Sydney's CBD sits on the harbour's south shore where sea breezes arrive reliably in summer afternoons. The dense tower core creates wind tunnels between skyscrapers." },
      { name: 'Surry Hills', slug: 'surry-hills', lat: -33.8864, lon: 151.2094, group: 'Inner East', description: "Surry Hills' dense Victorian terrace rows trap heat in summer. Its inland position from the Harbour means sea breezes arrive later and weaker than in CBD." },
      { name: 'Newtown', slug: 'newtown', lat: -33.8980, lon: 151.1800, group: 'Inner West', description: "Newtown's inner west position means it bakes in summer before the afternoon southerly arrives. King Street's urban canyon amplifies heat in the middle of the day." },
      { name: 'Bondi Beach', slug: 'bondi-beach', lat: -33.8914, lon: 151.2743, group: 'Eastern Suburbs', description: "Bondi's ocean beach faces southeast — it catches the southerly buster head-on, making it one of Sydney's most dramatically weather-shifted spots when the sea change arrives." },
      { name: 'Manly', slug: 'manly', lat: -33.7969, lon: 151.2877, group: 'Northern Beaches', description: "Manly's isthmus between the Harbour and Pacific Ocean gives it genuine coastal weather from two directions — harbour breezes and open ocean swell conditions." },
      { name: 'Paddington', slug: 'paddington', lat: -33.8835, lon: 151.2290, group: 'Inner East', description: "Paddington's elevated ridge between the CBD and Bondi catches sea breezes from the east while its Victorian terrace density retains daytime heat." },
      { name: 'Glebe', slug: 'glebe', lat: -33.8801, lon: 151.1870, group: 'Inner West', description: "Glebe's peninsula between Blackwattle Bay and Rozelle Bay gives it water exposure on two sides, with harbour breezes reaching the foreshore." },
      { name: 'Darlinghurst', slug: 'darlinghurst', lat: -33.8775, lon: 151.2215, group: 'Inner East', description: "Darlinghurst's elevated terrain between the CBD and inner east provides good ventilation, and Oxford Street acts as an east-west wind corridor." },
      { name: 'Pyrmont', slug: 'pyrmont', lat: -33.8720, lon: 151.1970, group: 'Inner Sydney', description: "Pyrmont's Darling Harbour and Blackwattle Bay waterfront means consistent harbour breezes. The redeveloped peninsula has become significantly greener and cooler than its industrial past." },
      { name: 'North Sydney', slug: 'north-sydney', lat: -33.8401, lon: 151.2072, group: 'North Shore', description: "North Sydney's harbour-facing commercial district gets strong northerly winds off the Harbour. The Harbour Bridge creates local turbulence on windy days." },
      { name: 'Parramatta', slug: 'parramatta', lat: -33.8148, lon: 151.0017, group: 'Western Sydney', description: "Parramatta in Sydney's west is the classic example of Sydney's urban heat island — regularly 5–10°C hotter than coastal suburbs during summer heat waves." },
      { name: 'Chatswood', slug: 'chatswood', lat: -33.7962, lon: 151.1836, group: 'North Shore', description: "Chatswood's north shore position catches northern sea breezes off Middle Harbour, keeping it measurably cooler than western suburbs in summer." },
      { name: 'Mosman', slug: 'mosman', lat: -33.8265, lon: 151.2453, group: 'North Shore', description: "Mosman's position on a harbour headland with water on three sides gives it exceptional harbour breezes and among Sydney's most pleasant summer microclimates." },
      { name: 'Balmain', slug: 'balmain', lat: -33.8604, lon: 151.1792, group: 'Inner West', description: "Balmain's peninsula into the Parramatta River gives it water exposure on three sides, with consistent harbour breezes and cooling sea air." },
      { name: 'Redfern', slug: 'redfern', lat: -33.8929, lon: 151.2042, group: 'Inner South', description: "Redfern's flat inland position south of the CBD means heat accumulates without much coastal ventilation. The suburb is warming faster than coastal areas due to densification." },
    ],
  },
  {
    name: 'Los Angeles',
    slug: 'los-angeles',
    country: 'United States',
    flag: '🇺🇸',
    lat: 34.0522,
    lon: -118.2437,
    timezone: 'America/Los_Angeles',
    description: "Los Angeles has one of the world's most varied urban microclimates, shaped by the Pacific Ocean, the Santa Ana winds, and dramatic elevation changes from sea level to over 5,000 feet within city limits. Coastal neighborhoods sit inside a near-permanent marine layer that holds morning fog through noon, while inland valleys bake 15–25°F hotter in summer. Dry offshore Santa Ana wind events drive extreme fire danger and push temperatures into the 90s even in October.",
    districts: [
      { name: 'Santa Monica', slug: 'santa-monica', lat: 34.0195, lon: -118.4912, group: 'Coastal', description: "Santa Monica sits directly on the Pacific coast and lives inside the marine layer for much of June and July — 'June Gloom' keeps mornings overcast and temperatures 10–15°F cooler than downtown. Sea breezes arrive reliably by early afternoon, making it one of the coolest zones in the metro." },
      { name: 'Downtown LA', slug: 'downtown-la', lat: 34.0407, lon: -118.2468, group: 'Downtown', description: "Downtown's dense high-rise corridor traps heat with one of the strongest urban heat island effects in the city, running 5–8°F warmer than coastal neighborhoods on summer evenings. Towers along Figueroa funnel and intensify wind in an otherwise calm basin." },
      { name: 'Hollywood Hills', slug: 'hollywood-hills', lat: 34.1184, lon: -118.3267, group: 'Hills', description: "Sitting at 800–1,400 feet, the Hollywood Hills break free of the marine layer that blankets the flats below, delivering more sunshine hours but also exposure to hot, dry Santa Ana winds that funnel through canyon corridors." },
      { name: 'Venice Beach', slug: 'venice-beach', lat: 34.0000, lon: -118.4695, group: 'Coastal', description: "Venice's wide beachfront sits in a persistent onshore flow zone — sea breezes arrive by 10 AM and keep afternoon temperatures 12–18°F lower than the San Fernando Valley just 15 miles inland." },
      { name: 'Silver Lake', slug: 'silver-lake', lat: 34.0870, lon: -118.2713, group: 'East Side', description: "Silver Lake's hilly terrain and the reservoir create mild local temperature moderation, but its inland position means it misses the strongest marine layer effects, with summers noticeably hotter than Westside neighborhoods." },
      { name: 'Koreatown', slug: 'koreatown', lat: 34.0587, lon: -118.3006, group: 'Central', description: "Flat, densely built Koreatown sits in central LA with minimal tree cover and high impervious surface coverage, making it one of the metro's most significant urban heat islands — regularly 8–10°F above coastal readings." },
      { name: 'West Hollywood', slug: 'west-hollywood', lat: 34.0900, lon: -118.3617, group: 'West Side', description: "WeHo sits at the foot of the Santa Monica Mountains, catching some elevation-driven cooling at its northern edges while its flat commercial strip retains heat. Marine layer usually burns off here by noon." },
      { name: 'Malibu', slug: 'malibu', lat: 34.0259, lon: -118.7798, group: 'Coastal', description: "Malibu's 21-mile Pacific coastline delivers the metro's purest marine climate — cool, foggy mornings, reliable afternoon sea breezes, and exceptional exposure to Southern California's rare coastal storms and high surf." },
      { name: 'Pasadena', slug: 'pasadena', lat: 34.1478, lon: -118.1445, group: 'San Gabriel Valley', description: "Pasadena sits at the foot of the San Gabriel Mountains and is a classic inland heat trap — summer highs average 95–100°F, and Santa Ana winds funnel directly out of the mountain canyons above the city." },
      { name: 'Burbank', slug: 'burbank', lat: 34.1808, lon: -118.3090, group: 'San Fernando Valley', description: "Burbank in the eastern San Fernando Valley is shielded from marine air by the Santa Monica Mountains, creating scorching summers where 100°F days are routine and the marine layer rarely penetrates before evening." },
      { name: 'Long Beach', slug: 'long-beach', lat: 33.7701, lon: -118.1937, group: 'South Bay', description: "Long Beach faces the open San Pedro Bay with a south-facing coastline that catches sea breezes differently than north-facing Santa Monica — afternoon winds blow onshore from the southwest, cooling the downtown waterfront significantly." },
      { name: 'Culver City', slug: 'culver-city', lat: 34.0211, lon: -118.3965, group: 'West Side', description: "Culver City sits in a transitional marine-inland zone where the marine layer reliably arrives but often burns off by 11 AM. Temperatures run 5–8°F warmer than Santa Monica but 8–10°F cooler than the Valley." },
      { name: 'Echo Park', slug: 'echo-park', lat: 34.0782, lon: -118.2606, group: 'East Side', description: "Echo Park Lake provides a small but measurable evaporative cooling effect on the surrounding blocks. Its hilly terrain creates pockets of shade and breeze that vary dramatically street to street." },
      { name: 'El Segundo', slug: 'el-segundo', lat: 33.9192, lon: -118.4165, group: 'South Bay', description: "El Segundo's coastal position just south of LAX delivers consistent afternoon sea breezes and morning marine layer. Its flat terrain and ocean exposure make it one of the cooler communities in Los Angeles County." },
      { name: 'Woodland Hills', slug: 'woodland-hills', lat: 34.1683, lon: -118.6059, group: 'San Fernando Valley', description: "Deep in the western San Fernando Valley, Woodland Hills is LA's hottest major neighborhood — the valley's bowl shape traps heat, marine air rarely reaches it, and temperatures of 105–110°F occur multiple times each summer." },
    ],
  },
  {
    name: 'Chicago',
    slug: 'chicago',
    country: 'United States',
    flag: '🇺🇸',
    lat: 41.8781,
    lon: -87.6298,
    timezone: 'America/Chicago',
    description: "Chicago earns its 'Windy City' nickname from Lake Michigan's powerful influence — the lake moderates summer heat along the lakefront while keeping the city 10–15°F cooler than inland suburbs. Winters bring brutal polar vortex events with wind chills below -40°F, while summers can swing from pleasant lake breezes to stifling humidity. The city experiences dramatic weather between seasons, with the lakefront and the inland West Side neighborhoods living in measurably different climates.",
    districts: [
      { name: 'The Loop', slug: 'the-loop', lat: 41.8827, lon: -87.6233, group: 'Downtown', description: "The Loop's skyscraper canyons along LaSalle and Wacker create intense wind tunnel effects that earned Chicago its nickname — gusts between towers routinely exceed 30 mph when the larger environment is calm. In summer, lake air from Grant Park moderates temperatures." },
      { name: 'Lincoln Park', slug: 'lincoln-park', lat: 41.9219, lon: -87.6468, group: 'North Side', description: "Lincoln Park's namesake green space and direct Lake Michigan frontage give it the classic Chicago lakefront microclimate — cooler summers, lake breezes, and slightly more precipitation than inland neighborhoods." },
      { name: 'Wicker Park', slug: 'wicker-park', lat: 41.9088, lon: -87.6771, group: 'North Side', description: "Wicker Park sits inland where lake influence fades — summers run 4–6°F hotter than the lakefront, and the dense two-flat residential fabric creates typical urban heat retention with minimal wind shelter." },
      { name: 'Hyde Park', slug: 'hyde-park', lat: 41.7943, lon: -87.5907, group: 'South Side', description: "Hyde Park's location directly on the Lake Michigan shoreline with Jackson Park and the Museum of Science lagoon creates a pronounced coastal microclimate — summers are significantly cooler and breezier than inland South Side neighborhoods." },
      { name: 'Wrigleyville', slug: 'wrigleyville', lat: 41.9484, lon: -87.6553, group: 'North Side', description: "Wrigleyville sits a mile inland from the lake — close enough to catch strong lake breezes on windy days but far enough to heat up significantly on calm summer afternoons, which affects day game conditions at Wrigley Field." },
      { name: 'West Loop', slug: 'west-loop', lat: 41.8826, lon: -87.6490, group: 'Downtown', description: "The West Loop's rapid densification and conversion of warehouses has created a growing urban heat island. Lake breezes rarely penetrate this far west, and summer temperatures run 6–8°F above lakefront readings." },
      { name: 'Logan Square', slug: 'logan-square', lat: 41.9217, lon: -87.7005, group: 'North Side', description: "Logan Square's boulevard system with wide tree-lined parkways provides Chicago's best street-level wind buffering in a non-lakefront neighborhood, creating a marginally more comfortable summer microclimate than adjacent dense areas." },
      { name: 'Pilsen', slug: 'pilsen', lat: 41.8534, lon: -87.6583, group: 'South Side', description: "Pilsen's flat South Side terrain and distance from the lake makes it one of Chicago's warmer summer neighborhoods, with high humidity retention and limited cross-ventilation in its dense residential blocks." },
      { name: 'Gold Coast', slug: 'gold-coast', lat: 41.9050, lon: -87.6284, group: 'North Side', description: "The Gold Coast's direct lakefront position delivers the most dramatic lake effect in the city — afternoon lake breezes keep summer temperatures 8–10°F below inland readings, but winter brings vicious wind off frozen Lake Michigan." },
      { name: 'Bronzeville', slug: 'bronzeville', lat: 41.8364, lon: -87.6167, group: 'South Side', description: "Bronzeville sits between the lake and Chicago's industrial South Side — close enough for moderate lake influence in summer but historically underserved by tree canopy, contributing to heat vulnerability during heat events." },
      { name: 'Streeterville', slug: 'streeterville', lat: 41.8926, lon: -87.6192, group: 'Downtown', description: "Streeterville's peninsula into Lake Michigan puts it on three sides surrounded by lake air — it consistently records the city's lowest summer temperatures and highest sustained winds, with the lake exerting near-total weather dominance." },
      { name: 'Andersonville', slug: 'andersonville', lat: 41.9806, lon: -87.6672, group: 'Far North', description: "Far North Side Andersonville sits beyond the lake's strongest influence — summers are warmer and more humid than the lakefront, though northerly lake breezes still moderate the worst heat days compared to western suburbs." },
      { name: 'Bridgeport', slug: 'bridgeport', lat: 41.8332, lon: -87.6498, group: 'South Side', description: "Bridgeport's South Side industrial heritage left it with low tree coverage and high heat-absorbing pavement. The Chicago River's South Branch provides minimal cooling, and summer heat index values consistently exceed the lakefront by 10°F." },
      { name: 'Rogers Park', slug: 'rogers-park', lat: 42.0121, lon: -87.6695, group: 'Far North', description: "Rogers Park at Chicago's northern tip has genuine lakefront access — the beach and lake presence moderate summer temperatures and create a distinct microclimate compared to the dense inland neighborhoods just blocks west." },
      { name: 'River North', slug: 'river-north', lat: 41.8917, lon: -87.6345, group: 'Downtown', description: "River North's dense gallery and restaurant district sits just inland from the lakefront, catching lake breezes on strong wind days. The Chicago River's North Branch creates a minor cooling corridor through the neighborhood." },
    ],
  },
  {
    name: 'Miami',
    slug: 'miami',
    country: 'United States',
    flag: '🇺🇸',
    lat: 25.7617,
    lon: -80.1918,
    timezone: 'America/New_York',
    description: "Miami's subtropical climate means hot, humid summers with daily afternoon thunderstorms driven by Atlantic sea breezes colliding with Gulf air, and warm, dry winters that attract millions of visitors. The city sits at sea level on a limestone peninsula between Biscayne Bay and the Atlantic Ocean, giving coastal neighborhoods constant ocean breezes while inland areas bake in intense urban heat. Hurricane season runs June through November, with the entire metro exposed to major storm risk.",
    districts: [
      { name: 'South Beach', slug: 'south-beach', lat: 25.7825, lon: -80.1300, group: 'Miami Beach', description: "South Beach's barrier island position between the Atlantic Ocean and Biscayne Bay delivers ocean breezes from both directions — it's consistently 5–8°F cooler than downtown Miami on summer afternoons, with the ocean providing direct storm exposure during hurricane season." },
      { name: 'Brickell', slug: 'brickell', lat: 25.7584, lon: -80.1942, group: 'Downtown', description: "Brickell's rapidly densifying skyscraper corridor along Biscayne Bay creates growing wind tunnel effects at street level. Bay breezes moderate temperatures but the glass tower cluster amplifies solar radiation, creating extreme radiant heat between buildings." },
      { name: 'Wynwood', slug: 'wynwood', lat: 25.8016, lon: -80.1995, group: 'Midtown', description: "Wynwood's flat inland position with low-rise warehouse buildings and limited tree canopy creates Miami's classic urban heat trap — afternoon temperatures regularly exceed the coast by 8–10°F, and humidity from afternoon thunderstorms is intense." },
      { name: 'Coral Gables', slug: 'coral-gables', lat: 25.7215, lon: -80.2684, group: 'South Miami', description: "Coral Gables' mature tree canopy — some of the densest in the metro — provides significant urban cooling, with temperatures measurably lower than unshaded neighborhoods. The city's Mediterranean Revival architecture also limits solar gain." },
      { name: 'Little Havana', slug: 'little-havana', lat: 25.7718, lon: -80.2290, group: 'Central', description: "Little Havana's dense commercial and residential blocks with modest tree coverage create classic urban heat island conditions — summer temperatures run 6–9°F above Coral Gables despite similar inland positions." },
      { name: 'Coconut Grove', slug: 'coconut-grove', lat: 25.7350, lon: -80.2386, group: 'South Miami', description: "Coconut Grove's historic tree canopy along Biscayne Bay is Miami's best natural air conditioning — bayfront breezes combined with dense shade trees create one of the most comfortable summer microclimates in the metro." },
      { name: 'Design District', slug: 'design-district', lat: 25.8127, lon: -80.1940, group: 'Midtown', description: "The Design District's mix of low-rise and mid-rise buildings inland from the bay gets afternoon sea breeze relief later than coastal neighborhoods, and the heat-absorbing retail and warehouse surfaces create midday temperature spikes." },
      { name: 'Key Biscayne', slug: 'key-biscayne', lat: 25.6936, lon: -80.1620, group: 'Coastal Islands', description: "Key Biscayne's barrier island surrounded by open Atlantic water delivers the strongest and most consistent ocean breezes in greater Miami — it's routinely the coolest spot in the metro on hot summer days and the most exposed during tropical storms." },
      { name: 'Overtown', slug: 'overtown', lat: 25.7874, lon: -80.2026, group: 'Downtown', description: "Overtown's dense urban core with limited tree canopy and high impervious surface cover makes it one of Miami's most heat-vulnerable neighborhoods — inland position blocks bay breezes and urban heat island temperatures push 10°F above coastal readings." },
      { name: 'Hialeah', slug: 'hialeah', lat: 25.8577, lon: -80.2781, group: 'Northwest Miami', description: "Hialeah sits well inland from both the Atlantic and Biscayne Bay, placing it firmly in Miami's hottest zone — ocean breezes rarely penetrate this far west, and the flat, densely built landscape retains intense tropical heat." },
      { name: 'Miami Beach', slug: 'miami-beach', lat: 25.8103, lon: -80.1409, group: 'Miami Beach', description: "Northern Miami Beach on the barrier island gets steady Atlantic cross-ventilation — the island's narrow width means sea breezes reach every block, and summer temperatures are naturally moderated by ocean exposure from the east and Biscayne Bay from the west." },
      { name: 'Aventura', slug: 'aventura', lat: 25.9565, lon: -80.1393, group: 'North Miami', description: "Aventura's Intracoastal Waterway and proximity to the Atlantic create consistent maritime breezes that moderate summer heat — the waterfront developments benefit from the same ocean cooling that gives Miami Beach its favorable microclimate." },
      { name: 'Little Haiti', slug: 'little-haiti', lat: 25.8311, lon: -80.1979, group: 'North Miami', description: "Little Haiti's flat inland neighborhood north of downtown has limited coastal influence and minimal tree canopy, creating hot and humid conditions that intensify during Miami's daily afternoon thunderstorm season." },
      { name: 'Doral', slug: 'doral', lat: 25.8194, lon: -80.3550, group: 'West Miami', description: "Doral in western Miami-Dade is among the hottest spots in the metro — maximum distance from ocean breezes, flat terrain, and a heavily developed commercial landscape create extreme urban heat island conditions in summer." },
      { name: 'Homestead', slug: 'homestead', lat: 25.4687, lon: -80.4776, group: 'South Dade', description: "Homestead at Miami's southern edge has proximity to Biscayne National Park and Florida Bay, providing some maritime moderation. However, its agricultural inland character means less urban heat island effect but more exposure to unfiltered tropical weather." },
    ],
  },
  {
    name: 'Singapore',
    slug: 'singapore',
    country: 'Singapore',
    flag: '🇸🇬',
    lat: 1.3521,
    lon: 103.8198,
    timezone: 'Asia/Singapore',
    description: "Singapore sits just 1.4 degrees north of the equator with a uniformly hot and humid tropical climate — temperatures hover between 25–33°C year-round with no true seasons. The island experiences two monsoon phases: the Northeast Monsoon from December to March and the Southwest Monsoon from June to September, bringing varying rainfall patterns. Dense urban development creates an intense heat island in the city center, while coastal and park areas benefit from sea breezes and green cooling effects.",
    districts: [
      { name: 'Marina Bay', slug: 'marina-bay', lat: 1.2789, lon: 103.8536, group: 'Central', description: "Marina Bay's water-facing position between the Singapore Strait and the reservoir delivers consistent sea breezes that slightly moderate the intense tropical heat. The bay's open water amplifies the humidity sensation, particularly during the Southwest Monsoon." },
      { name: 'Orchard Road', slug: 'orchard-road', lat: 1.3048, lon: 103.8318, group: 'Central', description: "Orchard Road's dense shopping mall corridor creates a powerful urban heat island despite the tree-lined street above. Air conditioning exhaust from the malls significantly raises ambient temperatures, making outdoor conditions hotter than the surrounding residential areas." },
      { name: 'Chinatown', slug: 'chinatown', lat: 1.2838, lon: 103.8440, group: 'Central South', description: "Chinatown's dense shophouse architecture and narrow streets trap heat intensely. The historic low-rise blocks have minimal natural ventilation, and the area's central position away from the coast means sea breezes provide little relief." },
      { name: 'Little India', slug: 'little-india', lat: 1.3066, lon: 103.8518, group: 'Central', description: "Little India's dense commercial activity generates significant waste heat, and its inland position between two expressways traps air. Afternoon heat index values here regularly exceed 40°C during non-monsoon months." },
      { name: 'Sentosa', slug: 'sentosa', lat: 1.2494, lon: 103.8303, group: 'Southern Islands', description: "Sentosa Island is surrounded by the Singapore Strait on three sides, bringing consistent sea breezes that make it measurably cooler and less humid than the mainland. Beach-facing areas feel 3–5°C cooler on hot afternoons." },
      { name: 'Jurong', slug: 'jurong', lat: 1.3329, lon: 103.7436, group: 'West', description: "Jurong's heavy industrial and petrochemical complex in Singapore's west generates substantial waste heat. Its inland position from the Jurong Lake and limited green buffer means summer temperatures regularly exceed the island average." },
      { name: 'Changi', slug: 'changi', lat: 1.3644, lon: 103.9915, group: 'East', description: "Changi's eastern tip position facing the South China Sea delivers the island's strongest sea breezes from the east, particularly during the Northeast Monsoon. The airport and Changi Beach area benefit from genuine coastal cooling." },
      { name: 'Tampines', slug: 'tampines', lat: 1.3540, lon: 103.9443, group: 'East', description: "Tampines' dense public housing towers in eastern Singapore are partially sheltered from sea breezes by intervening development. The Tampines Regional Centre's commercial heat adds to local temperatures, though green corridors provide partial relief." },
      { name: 'Woodlands', slug: 'woodlands', lat: 1.4382, lon: 103.7890, group: 'North', description: "Woodlands at Singapore's northern coast faces the Johor Strait, delivering northerly breezes from the Malay Peninsula. Its position at the island's edge means slightly better ventilation than central neighborhoods." },
      { name: 'Bishan', slug: 'bishan', lat: 1.3510, lon: 103.8480, group: 'Central North', description: "Bishan Park's river and wetland restoration project has created a measurable cooling corridor in central Singapore — the park's evaporative cooling reduces surrounding temperatures by 2–4°C compared to adjacent dense residential areas." },
      { name: 'Punggol', slug: 'punggol', lat: 1.4053, lon: 103.9021, group: 'North East', description: "Punggol's new waterway and coastal position on the northeastern tip bring sea breezes from the Johor Strait. The planned eco-town's extensive waterways and green spaces make it one of Singapore's most climate-resilient new developments." },
      { name: 'Queenstown', slug: 'queenstown', lat: 1.2942, lon: 103.8060, group: 'Central West', description: "Queenstown, one of Singapore's oldest public housing estates, has benefited from mature tree growth that provides significant shade cooling. Its position near the Southern Ridges park corridor gives it better ventilation than newer inland estates." },
      { name: 'Geylang', slug: 'geylang', lat: 1.3189, lon: 103.8906, group: 'Central East', description: "Geylang's dense low-rise commercial and residential buildings with high activity levels create notable urban heat. The Geylang River provides minimal cooling, and the active nightlife generates heat well into the early hours." },
      { name: 'Toa Payoh', slug: 'toa-payoh', lat: 1.3322, lon: 103.8474, group: 'Central', description: "Toa Payoh's mature public housing estate in central Singapore benefits from decades of tree growth that now substantially shades its streets. The Toa Payoh Town Park and multiple sports facilities provide green cooling buffers." },
      { name: 'Buona Vista', slug: 'buona-vista', lat: 1.3076, lon: 103.7902, group: 'West', description: "Buona Vista's One-North research corridor and the adjacent Clementi Forest reserve create an unusual microclimate for Singapore — the science park's planned layout allows better ventilation than organic commercial districts, and the forest provides measurable cooling." },
    ],
  },
  {
    name: 'Barcelona',
    slug: 'barcelona',
    country: 'Spain',
    flag: '🇪🇸',
    lat: 41.3851,
    lon: 2.1734,
    timezone: 'Europe/Madrid',
    description: "Barcelona's Mediterranean climate delivers hot, dry summers and mild, wet winters shaped by its position between the Pyrenees, the Collserola hills, and the Mediterranean Sea. The sea breeze (marinada) arrives reliably each summer afternoon, cooling the coast by 5–8°C while the inland upper neighborhoods retain heat. The Collserola ridge to the northwest blocks cold tramuntana winds while the city's gridded Eixample blocks create intense summer heat islands in the urban center.",
    districts: [
      { name: 'Gothic Quarter', slug: 'gothic-quarter', lat: 41.3826, lon: 2.1769, group: 'Old City', description: "The Gothic Quarter's narrow medieval streets between stone buildings are among Barcelona's hottest spots in summer — the canyon-like alleys block sea breezes and trap heat, while the thermal mass of ancient walls radiates warmth well into the night." },
      { name: 'Barceloneta', slug: 'barceloneta', lat: 41.3779, lon: 2.1905, group: 'Coastal', description: "Barceloneta's beachfront position delivers the full force of the Mediterranean sea breeze — afternoon marinada winds arrive here first and strongest, making it 5–7°C cooler than the Eixample just a kilometer inland on hot summer afternoons." },
      { name: 'Eixample', slug: 'eixample', lat: 41.3931, lon: 2.1629, group: 'Central', description: "Cerdà's Eixample grid creates notorious summer heat traps — the wide streets and uniformly high buildings minimize shade while maximizing solar absorption. Interior block courtyards provide some relief, but surface temperatures here regularly exceed 45°C in heatwaves." },
      { name: 'Gràcia', slug: 'gracia', lat: 41.4039, lon: 2.1557, group: 'Upper City', description: "Gràcia's village-like squares with mature plane trees create a more human-scale microclimate than the Eixample below. Its slight elevation and proximity to the Collserola hills delivers cooler evening temperatures as air drains down from the ridge." },
      { name: 'El Born', slug: 'el-born', lat: 41.3851, lon: 2.1840, group: 'Old City', description: "El Born's narrow medieval streets channel sea breezes from Barceloneta when the marinada is strong, providing afternoon relief. The Ciutadella Park nearby acts as a green lung with measurable cooling extending several blocks." },
      { name: 'Sarrià', slug: 'sarria', lat: 41.4024, lon: 2.1224, group: 'Upper City', description: "Sarrià sits at the foot of Collserola at 100–150 meters elevation, making it one of Barcelona's coolest residential neighborhoods — consistently 3–5°C below the Eixample in summer, with mountain breezes arriving as the coast heats up." },
      { name: 'Poble Sec', slug: 'poble-sec', lat: 41.3739, lon: 2.1590, group: 'Montjuïc', description: "Poble Sec lies on Montjuïc's lower slopes, catching mountain-to-sea drainage flows in the evening while its south-facing aspect absorbs intense afternoon sun. The Montjuïc gardens above act as a heat buffer." },
      { name: 'Poblenou', slug: 'poblenou', lat: 41.4012, lon: 2.2015, group: 'Coastal', description: "Poblenou's coastal and former industrial zone directly faces the Mediterranean, delivering the afternoon sea breeze reliably. Its proximity to the beach and relatively low-density development makes it one of the cooler parts of Barcelona's eastern expansion." },
      { name: 'Les Corts', slug: 'les-corts', lat: 41.3787, lon: 2.1331, group: 'West', description: "Les Corts' western position shields it from the strongest sea breezes, and the Camp Nou stadium area has high impervious surface coverage. On summer match days, crowd heat and traffic exhaust significantly raise local temperatures." },
      { name: 'Horta-Guinardó', slug: 'horta-guinardo', lat: 41.4261, lon: 2.1749, group: 'North East', description: "Horta-Guinardó's elevated north-facing hillside terrain gives it the most varied microclimate in Barcelona — valley sections trap heat while ridge streets receive Collserola mountain breezes, with temperature differences of 4–6°C between low and high areas." },
      { name: 'Sant Martí', slug: 'sant-marti', lat: 41.4156, lon: 2.2012, group: 'East', description: "Sant Martí spans from the seafront to inland blocks, creating a sharp coastal-inland microclimate gradient. Seafront streets benefit from sea breezes while inland blocks can be 6–8°C hotter on windless summer afternoons." },
      { name: 'Nou Barris', slug: 'nou-barris', lat: 41.4374, lon: 2.1762, group: 'North', description: "Nou Barris in Barcelona's northern hills sits farthest from the sea and highest in elevation, creating cooler summer temperatures but also exposure to cold tramuntana wind events from the Pyrenees in winter." },
      { name: 'Sants', slug: 'sants', lat: 41.3756, lon: 2.1399, group: 'West', description: "Sants' dense working-class neighborhood west of the Eixample is cut off from sea breezes by intervening development. The train station area generates significant thermal mass, and summer temperatures here rival the hottest Eixample blocks." },
      { name: 'Diagonal Mar', slug: 'diagonal-mar', lat: 41.4100, lon: 2.2200, group: 'Coastal', description: "Diagonal Mar's modern waterfront development at the end of Avinguda Diagonal faces the Mediterranean directly, receiving strong afternoon sea breezes and open coastal exposure. Its relatively low density compared to older neighborhoods allows good ventilation." },
      { name: 'Vall d\'Hebron', slug: 'vall-dhebron', lat: 41.4275, lon: 2.1510, group: 'North', description: "Vall d'Hebron's high elevation near Collserola delivers Barcelona's most pronounced mountain microclimate — temperatures average 4–6°C cooler than the waterfront in summer, with regular mountain breezes and higher rainfall than the coastal neighborhoods." },
    ],
  },
  {
    name: 'Toronto',
    slug: 'toronto',
    country: 'Canada',
    flag: '🇨🇦',
    lat: 43.6532,
    lon: -79.3832,
    timezone: 'America/Toronto',
    description: "Toronto's weather is dominated by Lake Ontario's massive thermal influence — the lake moderates temperatures year-round, delaying spring warmth and extending autumn's mild stretch, while generating lake-effect snow on the lakeshore in winter. The city experiences cold, snowy winters with polar vortex intrusions and warm, humid summers. Toronto's downtown core has a growing urban heat island, while the Scarborough Bluffs and lakefront neighborhoods experience distinctly cooler and more maritime conditions.",
    districts: [
      { name: 'Downtown Core', slug: 'downtown-core', lat: 43.6532, lon: -79.3832, group: 'Downtown', description: "Toronto's downtown canyon of glass towers along Bay and King Streets creates intense wind tunnel effects in winter — the towers channel Arctic winds down narrow corridors, creating effective temperatures 10°C below open-air readings. In summer, the same towers trap heat and block lake breezes." },
      { name: 'Kensington Market', slug: 'kensington-market', lat: 43.6541, lon: -79.4000, group: 'Downtown West', description: "Kensington Market's low-rise eclectic streetscape and pedestrian activity creates a more human-scale microclimate than the tower-dominated downtown core. Its position inland from the lake means summer heat builds without lake relief." },
      { name: 'Distillery District', slug: 'distillery-district', lat: 43.6503, lon: -79.3598, group: 'Downtown East', description: "The Distillery District's heritage brick buildings facing Lake Ontario catch the lake breeze more directly than districts further north. The Victorian industrial architecture's thermal mass moderates temperatures, staying cooler in summer and warmer in early spring." },
      { name: 'The Annex', slug: 'the-annex', lat: 43.6698, lon: -79.4046, group: 'Midtown', description: "The Annex's tree-canopied Victorian streetscape provides one of downtown Toronto's best natural cooling effects. Bloor Street's commercial activity adds heat, but the residential streets' mature tree coverage significantly offsets urban heat island conditions." },
      { name: 'Leslieville', slug: 'leslieville', lat: 43.6605, lon: -79.3320, group: 'East End', description: "Leslieville's east-end position is close enough to the lake to receive moderate lake breezes in summer but far enough that lake-effect snow impacts are less severe than the lakeshore. Its flat terrain allows good ventilation along east-west streets." },
      { name: 'Scarborough Bluffs', slug: 'scarborough-bluffs', lat: 43.7120, lon: -79.2340, group: 'East', description: "Scarborough's Bluffs rise 90 meters directly above Lake Ontario, creating one of Toronto's most dramatic microclimates — the elevation generates cooling updrafts in summer while the lake below moderates temperatures year-round." },
      { name: 'Etobicoke', slug: 'etobicoke', lat: 43.6205, lon: -79.5132, group: 'West', description: "Etobicoke's western lakeshore along Lake Ontario and the Humber River valley creates a distinctive lakefront microclimate, but inland Etobicoke north of Bloor is more continental — experiencing greater temperature extremes than the downtown core." },
      { name: 'North York', slug: 'north-york', lat: 43.7615, lon: -79.4111, group: 'North', description: "North York's distance from Lake Ontario removes the lake's moderating influence entirely — winters are colder, summers are hotter, and the urban heat island from its dense North York Centre development adds further intensity." },
      { name: 'Yorkville', slug: 'yorkville', lat: 43.6718, lon: -79.3953, group: 'Midtown', description: "Yorkville's upscale Bloor Street corridor has significant commercial heat generation from dense retail, hotels, and restaurants. Despite being only 2km from the lake, lake breezes rarely penetrate this far north on calm days." },
      { name: 'Riverdale', slug: 'riverdale', lat: 43.6665, lon: -79.3447, group: 'East End', description: "Riverdale's position in the Don Valley creates a localized river valley microclimate — cooler air drains from the valley on calm nights, and the Don Valley Parkway corridor channels winds from the lake northward." },
      { name: 'Forest Hill', slug: 'forest-hill', lat: 43.6996, lon: -79.4174, group: 'Midtown North', description: "Forest Hill's elevated terrain north of the city center with generous tree canopy makes it one of Toronto's cooler wealthy neighborhoods in summer — the tree coverage reduces urban heat island effect significantly compared to dense commercial corridors." },
      { name: 'Liberty Village', slug: 'liberty-village', lat: 43.6385, lon: -79.4213, group: 'Downtown West', description: "Liberty Village's former industrial buildings converted to lofts and offices have high thermal mass. Its position south of the rail corridor creates a heat trap with limited north-south ventilation, though lake breezes occasionally penetrate from the south." },
      { name: 'Rosedale', slug: 'rosedale', lat: 43.6802, lon: -79.3768, group: 'Midtown', description: "Rosedale's ravine system and mature tree canopy create Toronto's most significant natural cooling corridor north of downtown — the Don and Yellow Creek ravines channel cool air and their tree coverage reduces summer temperatures by 3–5°C." },
      { name: 'Junction', slug: 'junction', lat: 43.6656, lon: -79.4613, group: 'West End', description: "The Junction's west-end inland position removes it from lake influence and places it in the heart of Toronto's urban heat island. The Humber River valley to the west provides some cooling drainage, but summer heat builds noticeably here." },
      { name: 'Waterfront', slug: 'waterfront', lat: 43.6390, lon: -79.3760, group: 'Downtown South', description: "Toronto's revitalized Waterfront sits directly on Lake Ontario, experiencing the city's most pronounced lake effect — dramatically cooler in summer with reliable afternoon lake breezes, but exposed to intense blizzard conditions when winter storms cross the lake." },
    ],
  },
  {
    name: 'Amsterdam',
    slug: 'amsterdam',
    country: 'Netherlands',
    flag: '🇳🇱',
    lat: 52.3676,
    lon: 4.9041,
    timezone: 'Europe/Amsterdam',
    description: "Amsterdam's maritime climate is shaped by the North Sea just 15km to the west — mild, cloudy, and consistently windy with rain spread throughout the year. The city's extensive canal network moderates temperatures and creates fog corridors in autumn and winter. Amsterdam sits mostly below sea level on reclaimed polder land, with prevailing westerly winds off the North Sea dominating the weather. Summers are mild and pleasant, while winters are damp and grey rather than cold.",
    districts: [
      { name: 'Jordaan', slug: 'jordaan', lat: 52.3751, lon: 4.8814, group: 'West', description: "The Jordaan's network of narrow canals creates a characteristic microclimate — canal breezes flow through the streets in summer providing cooling, while autumn fog lingers in the low-lying channel corridors at night. Its dense 17th-century brick buildings retain heat well in summer." },
      { name: 'De Pijp', slug: 'de-pijp', lat: 52.3549, lon: 4.8992, group: 'South', description: "De Pijp's dense 19th-century apartment blocks and the Sarphatipark create a sheltered urban microclimate. The narrow east-west streets channel North Sea westerlies effectively, making this one of Amsterdam's breezier residential neighborhoods." },
      { name: 'Centrum', slug: 'centrum', lat: 52.3717, lon: 4.8922, group: 'Center', description: "Amsterdam's historic center built on peat bog sits at its lowest elevation, making it prone to heavy fog in autumn and winter when cooler air pools in the canal network. Westerly winds funnel down major streets while canal intersections create complex wind patterns." },
      { name: 'Oud-West', slug: 'oud-west', lat: 52.3636, lon: 4.8766, group: 'West', description: "Oud-West's Vondelpark provides Amsterdam's most significant urban green cooling effect — on hot summer days, the park lowers surrounding temperatures by 3–4°C and creates a pleasant afternoon microclimate extending several blocks." },
      { name: 'Noord', slug: 'noord', lat: 52.3984, lon: 4.9271, group: 'North', description: "Amsterdam Noord across the IJ waterway is more exposed to North Sea westerlies than the sheltered southern city, with open industrial and residential areas that have less buffering from prevailing winds. The IJ waterway creates a cooling maritime effect." },
      { name: 'Oost', slug: 'oost', lat: 52.3601, lon: 4.9414, group: 'East', description: "Amsterdam Oost's Flevopark along the Amstel and the large Oosterpark provide green cooling buffers in a densifying neighborhood. Its eastern position is slightly more sheltered from the dominant North Sea westerlies than western districts." },
      { name: 'Museumkwartier', slug: 'museumkwartier', lat: 52.3591, lon: 4.8811, group: 'South', description: "The Museum Quarter's combination of Vondelpark, Museumplein's open expanse, and the Concertgebouw area creates Amsterdam's most pleasant summer microclimate — open spaces allow ventilation while mature trees provide shade." },
      { name: 'Plantage', slug: 'plantage', lat: 52.3665, lon: 4.9116, group: 'Center East', description: "The Plantage district's tree-lined streets and the Artis Zoo's mature vegetation create a significantly cooler microclimate than the dense canal center. The Nieuwe Herengracht provides canal cooling while tree coverage reduces solar gain." },
      { name: 'Bijlmer', slug: 'bijlmer', lat: 52.3121, lon: 4.9503, group: 'South East', description: "Bijlmer's modernist high-rise towers in southeastern Amsterdam create complex wind patterns around the base of buildings while the elevated walkways experience strong gusts. The surrounding green spaces and water features moderate summer heat in this suburban district." },
      { name: 'Bos en Lommer', slug: 'bos-en-lommer', lat: 52.3795, lon: 4.8549, group: 'West', description: "Bos en Lommer sits at Amsterdam's western edge closer to the North Sea — its more open urban fabric and position means stronger westerly winds reach the streets directly, making it breezier but also more exposed to wet North Sea weather." },
      { name: 'Oud-Zuid', slug: 'oud-zuid', lat: 52.3473, lon: 4.8849, group: 'South', description: "Oud-Zuid's affluent southern neighborhoods with larger properties and mature garden trees create one of Amsterdam's greener and more temperature-moderate areas. The Vondelpark and Beatrixpark provide major cooling anchors on either side." },
      { name: 'Westerpark', slug: 'westerpark', lat: 52.3869, lon: 4.8714, group: 'North West', description: "The Westerpark's large green space along the former Westergasfabriek industrial site creates a local cooling pocket in the northwestern city. Its position near the North Sea Canal means occasional industrial wind patterns mix with urban airflow." },
      { name: 'IJburg', slug: 'ijburg', lat: 52.3576, lon: 5.0075, group: 'East (Islands)', description: "IJburg's artificial islands in the IJmeer lake east of Amsterdam experience the most exposed maritime conditions in the city — surrounded by open water, the islands receive unimpeded wind from all directions and experience the most dramatic temperature moderation." },
      { name: 'Waterlooplein', slug: 'waterlooplein', lat: 52.3678, lon: 4.9043, group: 'Center', description: "Waterlooplein's position at the confluence of the Amstel river and the canal ring creates dynamic water-driven wind patterns. The low-lying riverside location makes it prone to autumn fog and canal moisture on cold clear nights." },
      { name: 'Sloterdijk', slug: 'sloterdijk', lat: 52.3877, lon: 4.8376, group: 'West', description: "Sloterdijk's business district near the Amsterdam port is Amsterdam's most wind-exposed commercial area — the open harbor and North Sea Canal create unobstructed westerly flow that makes outdoor conditions markedly windier than the sheltered canal city center." },
    ],
  },
  {
    name: 'Bangkok',
    slug: 'bangkok',
    country: 'Thailand',
    flag: '🇹🇭',
    lat: 13.7563,
    lon: 100.5018,
    timezone: 'Asia/Bangkok',
    description: "Bangkok's tropical savanna climate delivers three distinct seasons: a hot season from March to May with temperatures above 35°C and suffocating humidity, a wet season from June to October driven by the Southwest Monsoon with daily heavy downpours, and a cooler dry season from November to February that attracts most tourists. The city sits on a flat delta plain barely 1.5 meters above sea level, making it highly flood-prone during monsoon season. Bangkok's massive urban heat island is among Asia's most intense, with the river and canals providing the only meaningful natural cooling.",
    districts: [
      { name: 'Sukhumvit', slug: 'sukhumvit', lat: 13.7367, lon: 100.5647, group: 'East', description: "Sukhumvit's dense high-rise corridor traps heat intensely — the BTS Skytrain elevated track and towers block prevailing breezes, and the street-level heat island from vehicles and air conditioning exhaust makes outdoor temperatures feel 5–8°C hotter than Bangkok's already extreme baseline." },
      { name: 'Silom', slug: 'silom', lat: 13.7255, lon: 100.5290, group: 'Central', description: "Silom's banking and business district generates enormous waste heat from office towers and is distant enough from the Chao Phraya that river breezes provide minimal relief. The underground MRT and elevated BTS create microclimates at transit entry points." },
      { name: 'Rattanakosin', slug: 'rattanakosin', lat: 13.7500, lon: 100.4926, group: 'Old City', description: "The historic Rattanakosin island enclosed by the Chao Phraya River and canals receives river breezes from multiple directions, making it one of Bangkok's more naturally ventilated areas. The open temple grounds of Wat Pho and Wat Phra Kaew provide rare green relief." },
      { name: 'Chatuchak', slug: 'chatuchak', lat: 13.8000, lon: 100.5500, group: 'North', description: "Chatuchak's weekend market — one of the world's largest — creates an extreme localized heat event when operating, with vendor heat, crowd body heat, and zero shade coverage pushing apparent temperatures above 45°C. The adjacent park provides relief on non-market days." },
      { name: 'Thonburi', slug: 'thonburi', lat: 13.7244, lon: 100.4800, group: 'West Bank', description: "Thonburi across the Chao Phraya River retains Bangkok's historic canal network more than the east bank, giving it evaporative cooling from the khlongs that measurably reduces ambient temperatures in canal-adjacent streets compared to the denser east side." },
      { name: 'Chinatown (Yaowarat)', slug: 'chinatown-yaowarat', lat: 13.7398, lon: 100.5104, group: 'Central', description: "Bangkok's Chinatown along Yaowarat Road is one of the city's hottest urban environments — the narrow street, cooking heat from hundreds of restaurants, and dense pedestrian activity create ambient temperatures consistently 4–6°C above open areas." },
      { name: 'Asok', slug: 'asok', lat: 13.7369, lon: 100.5601, group: 'East', description: "The Asok interchange where Sukhumvit and the Petchaburi expressway meet is Bangkok's most densely trafficked junction, generating extreme surface heat from vehicles. The transit hub's underground connections provide occasional relief but surface conditions are among the city's most oppressive." },
      { name: 'Riverside', slug: 'riverside', lat: 13.7220, lon: 100.5050, group: 'Central South', description: "Bangkok's riverside along the Chao Phraya between the Oriental and Shangri-La hotels consistently records the city's lowest outdoor temperatures — river breezes off the wide Chao Phraya reduce heat index values by 5–8°C compared to inland streets just 500 meters away." },
      { name: 'Khao San Road', slug: 'khao-san-road', lat: 13.7583, lon: 100.4980, group: 'Old City', description: "Khao San Road's pedestrian strip near Banglamphu generates significant nighttime heat from concentrated bars, restaurants and tourism activity. Its location near the Chao Phraya allows some river breezes but the alley character traps daytime heat effectively." },
      { name: 'Lat Phrao', slug: 'lat-phrao', lat: 13.8184, lon: 100.5693, group: 'North', description: "Lat Phrao's northern suburban position is most affected by Bangkok's urban heat island without the river's moderating influence. The elevated expressways and commercial development retain heat, and flooding risk during the Southwest Monsoon is among the highest in the metro." },
      { name: 'Bang Na', slug: 'bang-na', lat: 13.6667, lon: 100.6000, group: 'South East', description: "Bang Na's flat southeastern sprawl near Bangkok's industrial port is among the hottest zones in the metro — minimal tree canopy, high impervious surface coverage, and distance from the river create extreme heat island conditions during the pre-monsoon hot season." },
      { name: 'Phra Khanong', slug: 'phra-khanong', lat: 13.7025, lon: 100.5922, group: 'South East', description: "Phra Khanong's Klong Toei canal network provides localized evaporative cooling that distinguishes its microclimate from adjacent inland neighborhoods. The canal corridors channel breezes from the Gulf of Thailand, arriving strongest in the late afternoon." },
      { name: 'Don Mueang', slug: 'don-mueang', lat: 13.9125, lon: 100.5994, group: 'Far North', description: "Don Mueang in Bangkok's far north is the flattest and most flood-prone part of the metro — the airport's open tarmac creates heat emission at scale, and the area's low elevation makes it among the most severe flood victims during intense monsoon events." },
      { name: 'Nonthaburi', slug: 'nonthaburi', lat: 13.8622, lon: 100.5134, group: 'North West', description: "Nonthaburi's Chao Phraya riverside north of Bangkok maintains the river's cooling influence and retains more green space than the urban core. The river ferry corridor provides consistent airflow, and the lower development density reduces heat island intensity." },
      { name: 'Siam', slug: 'siam', lat: 13.7455, lon: 100.5339, group: 'Central', description: "Siam Square is Bangkok's commercial epicenter and thermal hotspot — the convergence of six BTS lines, multiple mega-malls, and dense pedestrian crowds generates extraordinary waste heat. Air conditioning exhaust from the malls creates a heated street-level environment even at night." },
    ],
  },
  {
    name: 'Mexico City',
    slug: 'mexico-city',
    country: 'Mexico',
    flag: '🇲🇽',
    lat: 19.4326,
    lon: -99.1332,
    timezone: 'America/Mexico_City',
    description: "Mexico City's climate is defined by its extraordinary elevation of 2,240 meters above sea level — what would be a tropical city is instead spring-like year-round, with average temperatures between 12–24°C throughout the year. The city sits in the Valley of Mexico surrounded by volcanoes, which traps air pollution and creates intense thermal inversions in winter. A rainy season from June to September brings daily afternoon thunderstorms while the dry season from November to May is dusty and increasingly warm.",
    districts: [
      { name: 'Polanco', slug: 'polanco', lat: 19.4327, lon: -99.1944, group: 'West', description: "Polanco's wide, tree-lined boulevards and lower commercial density create a more pleasant microclimate than the city center. Its Chapultepec Forest adjacency provides significant cooling — Mexico City's largest park lowers surrounding temperatures by 3–5°C on warm afternoons." },
      { name: 'Roma Norte', slug: 'roma-norte', lat: 19.4173, lon: -99.1625, group: 'Central', description: "Roma Norte's early 20th-century residential blocks with generous balconies and tree-lined streets create one of CDMX's more comfortable urban microclimates. The neighborhood's elevation of ~2,250m and park spaces moderate temperatures compared to denser downtown areas." },
      { name: 'Condesa', slug: 'condesa', lat: 19.4115, lon: -99.1728, group: 'Central', description: "La Condesa's distinctive circular Parque México and Parque España create measurable cooling corridors through the neighborhood. The parks' tree canopy significantly reduces summer temperatures and provides refuge during the intense UV radiation of the dry season." },
      { name: 'Coyoacán', slug: 'coyoacan', lat: 19.3467, lon: -99.1617, group: 'South', description: "Coyoacán's historic village character in southern CDMX retains more green space and lower density than central neighborhoods. Its slightly lower elevation at ~2,200m and the Viveros de Coyoacán forest preserve create a distinctly cooler and more humid microclimate." },
      { name: 'Centro Histórico', slug: 'centro-historico', lat: 19.4326, lon: -99.1332, group: 'Downtown', description: "The historic center's dense colonial architecture with wide plazas creates sharp microclimate contrasts — the Zócalo's open stone expanse becomes searingly hot in the dry season sun while the narrow streets around it remain shaded and cool." },
      { name: 'Santa Fe', slug: 'santa-fe', lat: 19.3604, lon: -99.2742, group: 'West', description: "Santa Fe's modern business district sits at the highest elevation in the metro at ~2,450m on the edge of the Desierto de los Leones, making it measurably cooler and cloudier than downtown. Fog and low clouds are common morning occurrences." },
      { name: 'Xochimilco', slug: 'xochimilco', lat: 19.2571, lon: -99.1032, group: 'South', description: "Xochimilco's extensive lake and canal system in CDMX's south creates the metro's most unique microclimate — the chinampas and water channels generate evaporative cooling and maintain significantly higher humidity than the dry urban core." },
      { name: 'Tlalpan', slug: 'tlalpan', lat: 19.2954, lon: -99.1705, group: 'South', description: "Tlalpan's southern forests at Mexico City's highest elevation (up to 3,000m on the southern boundary) deliver the most dramatic alpine microclimate — significantly cooler, cloudier, and wetter than the city below, with occasional frost in winter." },
      { name: 'Reforma', slug: 'reforma', lat: 19.4285, lon: -99.1774, group: 'Central', description: "Paseo de la Reforma's wide tree-lined boulevard with central camellones creates a wind corridor through central Mexico City. The median trees and office tower facades create complex wind patterns, but the boulevard's open design allows better ventilation than narrow downtown streets." },
      { name: 'Narvarte', slug: 'narvarte', lat: 19.3954, lon: -99.1613, group: 'Central South', description: "Narvarte's residential grid south of Roma with moderate density and street trees creates a typical CDMX residential microclimate — pleasant in the dry season, humid and thunderstorm-prone in summer, and subject to pollution inversions in winter." },
      { name: 'Tepito', slug: 'tepito', lat: 19.4472, lon: -99.1217, group: 'Downtown North', description: "Tepito's densely packed market district with few trees and high commercial activity creates one of central CDMX's most intense urban heat islands. The permanent market stalls and vehicle emissions combine with minimal green space to trap heat." },
      { name: 'Azcapotzalco', slug: 'azcapotzalco', lat: 19.4831, lon: -99.1853, group: 'North', description: "Azcapotzalco's northern industrial history left significant pollution legacy and limited green space. Its lower elevation at the valley floor makes it prone to Mexico City's winter thermal inversions, where cold polluted air is trapped by warmer air above." },
      { name: 'Iztapalapa', slug: 'iztapalapa', lat: 19.3569, lon: -98.9903, group: 'East', description: "Iztapalapa in eastern CDMX sits in a drained lakebed at the valley's lowest point, making it the hottest and driest part of the city in the dry season. The former lake bottom soil is prone to dust storms when dry winds blow across the unprotected terrain." },
      { name: 'Del Valle', slug: 'del-valle', lat: 19.3818, lon: -99.1704, group: 'Central South', description: "Del Valle's large residential superblocks with generous interior garden space create one of CDMX's quieter and more temperature-moderate neighborhoods. The tree-lined streets and park spaces provide shade that markedly reduces midday temperatures versus more commercial areas." },
      { name: 'Pedregal', slug: 'pedregal', lat: 19.3161, lon: -99.1972, group: 'South', description: "Pedregal de San Ángel's neighborhood built on ancient lava flows retains the dark basalt rock's heat storage properties — the rough volcanic landscape absorbs intense solar radiation during the dry season while the adjacent UNAM campus grounds provide a cooler green contrast." },
    ],
  },
  {
    name: 'São Paulo',
    slug: 'sao-paulo',
    country: 'Brazil',
    flag: '🇧🇷',
    lat: -23.5505,
    lon: -46.6333,
    timezone: 'America/Sao_Paulo',
    description: "São Paulo's subtropical highland climate at 760 meters elevation gives it milder temperatures than coastal Brazilian cities, but the world's fourth-largest urban area has created an extreme urban heat island that raises city temperatures 5–10°C above surrounding rural areas. Summers are hot and wet with torrential afternoon downpours and flash flooding in low-lying areas, while winters are dry and cool with occasional cold fronts from the south. The city's explosive growth has replaced most natural vegetation, creating intense heat and poor ventilation.",
    districts: [
      { name: 'Paulista', slug: 'paulista', lat: -23.5614, lon: -46.6561, group: 'Central', description: "Avenida Paulista's dense financial tower corridor at São Paulo's highest central elevation creates strong urban wind tunnel effects — the ridge-top position and tower canyons generate persistent winds, but the glass towers amplify solar heat gain." },
      { name: 'Jardins', slug: 'jardins', lat: -23.5726, lon: -46.6611, group: 'Central South', description: "Jardins' upscale residential neighborhood with mature tree canopy and lower building density creates one of central São Paulo's more comfortable summer microclimates — tree shade significantly reduces surface temperatures compared to unshaded commercial corridors." },
      { name: 'Pinheiros', slug: 'pinheiros', lat: -23.5626, lon: -46.6901, group: 'West', description: "Pinheiros sits on the Pinheiros River valley, and while the river was channeled decades ago, the low-lying terrain still creates a drainage corridor for cold air at night. Flash flood risk is highest here during São Paulo's intense summer convective storms." },
      { name: 'Vila Madalena', slug: 'vila-madalena', lat: -23.5563, lon: -46.6930, group: 'West', description: "Vila Madalena's hilly topography creates significant microclimate variation between valley streets and hilltop locations. Higher positions catch São Paulo's prevailing southwesterly winds while valley pockets trap heat and morning fog." },
      { name: 'Itaim Bibi', slug: 'itaim-bibi', lat: -23.5856, lon: -46.6738, group: 'South', description: "Itaim Bibi's dense financial and residential towers in southern São Paulo create intense urban heat island conditions. The neighborhood's valley position below Paulista reduces natural ventilation and concentrates heat from the dense commercial activity." },
      { name: 'Moema', slug: 'moema', lat: -23.6041, lon: -46.6694, group: 'South', description: "Moema's leafy residential streets with mature trees and Ibirapuera Park nearby create one of the south zone's more pleasant microclimates. The park generates a significant cooling effect that extends into the surrounding residential blocks." },
      { name: 'Liberdade', slug: 'liberdade', lat: -23.5588, lon: -46.6364, group: 'Central South', description: "Liberdade's Japanese quarter sits on hilly terrain that creates varying ventilation conditions. The dense low-to-mid-rise commercial blocks trap heat in the valley while ridge positions allow better airflow during São Paulo's dry season southeast winds." },
      { name: 'Tatuapé', slug: 'tatuape', lat: -23.5429, lon: -46.5799, group: 'East', description: "Tatuapé's eastern zone neighborhood sits in an area of rapid densification without proportional green space expansion, intensifying the urban heat island. The flat terrain reduces natural ventilation and summer temperatures regularly exceed western neighborhoods by 4–6°C." },
      { name: 'Lapa', slug: 'lapa', lat: -23.5219, lon: -46.7016, group: 'West', description: "Lapa's industrial and residential mix along the Tietê River floodplain creates heat island conditions compounded by vehicular emissions from the Marginal Tietê expressway. The river valley topography traps pollution during temperature inversions." },
      { name: 'Santana', slug: 'santana', lat: -23.5059, lon: -46.6283, group: 'North', description: "Santana's northern zone position means cold fronts from the south arrive here weakened after traversing the city. The neighborhood's suburban character with moderate density gives it less intense urban heat than the dense center but more than São Paulo's rural periphery." },
      { name: 'Centro', slug: 'centro', lat: -23.5475, lon: -46.6361, group: 'Downtown', description: "São Paulo's historic center has some of the city's densest built environment and lowest tree coverage. The narrow canyon-like streets trap heat and block ventilation, and the concentration of commercial activity generates enormous waste heat — São Paulo's hottest urban district." },
      { name: 'Alphaville', slug: 'alphaville', lat: -23.5026, lon: -46.8444, group: 'West (Metro)', description: "Alphaville's planned suburban development 27km west of downtown sits above the Cotia valley and benefits from significantly lower urban heat island intensity than central São Paulo. However, its position beyond the Serra da Cantareira hills creates distinct weather separation from the city." },
      { name: 'Santo André', slug: 'santo-andre', lat: -23.6639, lon: -46.5383, group: 'ABC Region', description: "Santo André's industrial ABC region southeast of São Paulo sits in a valley that traps pollution and heat. Cold fronts from the southwest often arrive delayed and weakened after passing over the metropolitan area." },
      { name: 'Guarulhos', slug: 'guarulhos', lat: -23.4543, lon: -46.5333, group: 'North (Metro)', description: "Guarulhos north of São Paulo hosts the main international airport and experiences unique microclimate effects from flight operations and the Serra da Cantareira's northern slope. The Serra acts as a barrier that concentrates rainfall on its southern face above Guarulhos." },
      { name: 'Ibirapuera', slug: 'ibirapuera', lat: -23.5871, lon: -46.6576, group: 'South', description: "Ibirapuera Park is São Paulo's most significant urban cooling anchor — the 1.6 km² of forest and lakes lowers surrounding temperatures by 4–7°C on hot summer afternoons. The park's evapotranspiration creates a cool air mass that spills into adjacent Moema and Vila Mariana." },
    ],
  },

  {
      name: 'Istanbul',
      slug: 'istanbul',
      country: 'Turkey',
      flag: '🇹🇷',
      lat: 41.0082,
      lon: 28.9784,
      timezone: 'Europe/Istanbul',
      description: "Istanbul's climate is shaped by its unique position straddling the Bosphorus strait between Europe and Asia, where Black Sea and Sea of Marmara air masses collide. The city experiences a transitional climate between Mediterranean and oceanic, with humid summers, cool winters, and frequent fog along the strait. Significant microclimatic variation exists between exposed hilltops, sheltered valleys, dense historic cores, and waterfront neighborhoods, with the Bosphorus acting as a massive wind and cooling corridor through the urban fabric.",
      districts: [
        { name: 'Sultanahmet', slug: 'sultanahmet', lat: 41.0054, lon: 28.9768, group: 'Historic Peninsula', description: "Sultanahmet's dense Ottoman-era stone architecture and narrow streets on the Historic Peninsula's highest ridge create significant heat retention, while its triple-water exposure to the Golden Horn, Bosphorus, and Marmara provides cooling breezes from multiple directions. The elevated position above sea level makes it one of the windiest historic districts, with the open plazas around Hagia Sophia channeling strong northeast winds in winter." },
        { name: 'Beyoğlu', slug: 'beyoglu', lat: 41.0370, lon: 28.9770, group: 'Central European', description: "Beyoğlu's steep hillside rising from the Golden Horn creates strong thermal gradients — waterfront Karaköy can be 3–4°C warmer than the İstiklal Avenue ridge on still summer nights due to trapped humidity. The dense 19th-century apartment blocks along narrow streets limit ventilation but the elevated İstiklal corridor catches cross-winds between the Golden Horn and Bosphorus." },
        { name: 'Beşiktaş', slug: 'besiktas', lat: 41.0430, lon: 29.0070, group: 'Bosphorus European', description: "Beşiktaş's direct Bosphorus frontage exposes it to the powerful northeasterly poyraz winds that funnel through the strait, making it one of Istanbul's windiest and coolest central neighborhoods. The steep terrain rising sharply from the waterfront creates microclimatic layers, with hilltop areas experiencing significantly different wind and temperature conditions than the sheltered coves below." },
        { name: 'Kadıköy', slug: 'kadikoy', lat: 41.0227, lon: 29.0230, group: 'Asian Coastal', description: "Kadıköy's south-facing Marmara Sea exposure gives it warmer winters and more sunshine than European-side neighborhoods shielded by hills, and the broad coastal promenade at Moda catches consistent sea breezes. The dense commercial core around the ferry terminal traps heat and humidity, but proximity to the open Marmara moderates temperature extremes year-round." },
        { name: 'Üsküdar', slug: 'uskudar', lat: 41.0260, lon: 29.0155, group: 'Asian Bosphorus', description: "Üsküdar's position at the southern mouth of the Bosphorus on the Asian side exposes it to both strait winds and Marmara moisture, creating frequent morning fog that lingers in the valley behind Kız Kulesi. The hillside neighborhoods like Çamlıca rise to over 260m and experience noticeably cooler temperatures, with the forested Çamlıca Hill acting as a green lung that generates downslope cooling breezes in the evening." },
        { name: 'Sarıyer', slug: 'sariyer', lat: 41.1670, lon: 29.0500, group: 'Northern Bosphorus', description: "Sarıyer at the Black Sea entrance of the Bosphorus receives the full force of cold northerly winds and Black Sea moisture, making it Istanbul's wettest and foggiest district with 20–30% more annual rainfall than southern neighborhoods. The dense Belgrade Forest to the west acts as a massive humidity source and temperature buffer, keeping summer highs several degrees below the urban core." },
        { name: 'Fatih', slug: 'fatih', lat: 41.0186, lon: 28.9497, group: 'Historic Peninsula', description: "Fatih's position in the heart of the Historic Peninsula features extremely dense building fabric with minimal green space, creating one of Istanbul's most intense urban heat islands. The neighborhood sits on a broad hilltop plateau that receives Marmara winds from the south but is partially sheltered from Bosphorus breezes, leading to stagnant hot conditions during summer high-pressure events." },
        { name: 'Bakırköy', slug: 'bakirkoy', lat: 41.0050, lon: 28.8770, group: 'Western Marmara', description: "Bakırköy's flat coastal position along the Sea of Marmara gives it reliable onshore breezes that moderate summer heat, and the Botanical Garden and coastal parks provide localized cooling. However, the adjacent Atatürk Airport zone and E-5 highway corridor create a significant urban heat island effect inland, with asphalt surfaces radiating stored heat well into the night." },
        { name: 'Şişli', slug: 'sisli', lat: 41.0602, lon: 28.9872, group: 'Central European', description: "Şişli's high-rise business district around Mecidiyeköy and Levent creates severe wind-tunnel effects between tower blocks while simultaneously trapping heat at street level due to reduced sky view. The neighborhood's inland hilltop position isolates it from both Bosphorus and Marmara maritime moderation, making it one of Istanbul's hottest districts during summer heatwaves." },
        { name: 'Bebek', slug: 'bebek', lat: 41.0770, lon: 29.0440, group: 'Bosphorus European', description: "Bebek's sheltered bay along the Bosphorus creates a distinctive calm microclimate — the curved shoreline and surrounding hills protect it from the harshest poyraz winds that batter neighboring Arnavutköy and Rumeli Hisarı. The bay traps morning fog from the strait, and the tree-lined waterfront combined with low-density residential fabric keeps summer temperatures 2–3°C below nearby hilltop districts." },
        { name: 'Eminönü', slug: 'eminonu', lat: 41.0173, lon: 28.9714, group: 'Historic Peninsula', description: "Eminönü's position at the confluence of the Golden Horn and Bosphorus makes it one of Istanbul's most humidity-exposed districts, with persistent sea fog and damp conditions in autumn and winter. The crowded bazaar district around the Spice Market and narrow commercial streets trap both heat and moisture, creating oppressive conditions during summer while the open Galata Bridge waterfront catches strong cross-strait winds." },
        { name: 'Maltepe', slug: 'maltepe', lat: 40.9345, lon: 29.1290, group: 'Asian Southern', description: "Maltepe's broad south-facing Marmara coastline gives it the longest direct sun exposure of any Istanbul neighborhood and strong maritime influence that prevents frost well into winter. The flat reclaimed coastal strip is exposed to powerful southwesterly lodos winds that funnel across the Marmara, while the steep Aydos Hill backdrop to the north creates orographic rainfall enhancement during northerly flow." },
        { name: 'Beykoz', slug: 'beykoz', lat: 41.1320, lon: 29.1020, group: 'Northern Asian', description: "Beykoz's heavily forested hills along the upper Asian Bosphorus shore make it Istanbul's greenest and most climatically moderate district, with summer highs consistently 4–5°C below the urban core. The extensive tree canopy generates high humidity and frequent morning dew, while the narrow Bosphorus channel at Beykoz funnels northerly Black Sea winds to high velocities." },
        { name: 'Eyüpsultan', slug: 'eyupsultan', lat: 41.0485, lon: 28.9340, group: 'Golden Horn', description: "Eyüpsultan sits at the head of the Golden Horn estuary in a sheltered valley that traps both cold air in winter and heat in summer, creating Istanbul's most extreme diurnal temperature swings. The valley topography channels winds along the Golden Horn corridor but blocks cross-ventilation, and the surrounding Pierre Loti and cemetery hillsides create localized downslope cold air drainage on clear nights." },
        { name: 'Arnavutköy', slug: 'arnavutkoy', lat: 41.0680, lon: 29.0340, group: 'Bosphorus European', description: "Arnavutköy's exposed promontory jutting into the narrowing Bosphorus makes it one of Istanbul's most wind-battered neighborhoods, with the poyraz accelerating through the strait constriction to create wind-chill effects 5–7°C below measured temperatures in winter. The colorful wooden Ottoman waterfront houses face directly into the strait current, and their lack of insulation makes them especially vulnerable to the damp maritime cold that characterizes Bosphorus winters." },
      ],
    },

  {
      name: 'Mumbai',
      slug: 'mumbai',
      country: 'India',
      flag: '🇮🇳',
      lat: 19.0760,
      lon: 72.8777,
      timezone: 'Asia/Kolkata',
      description: "Mumbai's tropical maritime climate is defined by its peninsular geography — a narrow strip of reclaimed land flanked by the Arabian Sea to the west and Thane Creek to the east. The city experiences intense monsoon rainfall from June to September, with western-facing neighborhoods receiving significantly more precipitation due to direct exposure to moisture-laden onshore winds. Urban heat islands are extreme in the dense central districts, while coastal promenades and mangrove fringes provide localized cooling corridors.",
      districts: [
        { name: 'Colaba', slug: 'colaba', lat: 19.0048, lon: 72.8320, group: 'South Mumbai', description: "Colaba sits at the southernmost tip of Mumbai's peninsula, exposed to Arabian Sea breezes on three sides, making it one of the city's most naturally ventilated neighborhoods. The maritime exposure keeps temperatures 2–3°C below inland areas year-round but brings heavy salt spray and intense humidity during the monsoon." },
        { name: 'Marine Lines', slug: 'marine-lines', lat: 19.0558, lon: 72.8228, group: 'South Mumbai', description: "Marine Lines benefits from its direct western seafront along Marine Drive, where unobstructed onshore winds create a strong cooling corridor that extends several blocks inland. The Art Deco-era stone buildings along Back Bay retain daytime heat, creating noticeable warmth on calm evenings despite the coastal position." },
        { name: 'Dadar', slug: 'dadar', lat: 19.0178, lon: 72.8478, group: 'Central Mumbai', description: "Dadar's position at the narrowest point of Mumbai's peninsula gives it partial access to both western sea breezes and eastern harbor air, though dense mid-rise construction limits ventilation at street level. Shivaji Park's large open ground acts as a localized cooling island, with evening temperatures around the park measurably lower than surrounding blocks." },
        { name: 'Bandra', slug: 'bandra', lat: 19.0596, lon: 72.8295, group: 'Western Suburbs', description: "Bandra's elevated western ridge along Bandstand and Land's End catches direct Arabian Sea winds, making it one of the breeziest neighborhoods in the western suburbs. The eastern side near the railway station is sheltered from sea breezes and densely built, creating a stark microclimate difference of 3–4°C within the same neighborhood." },
        { name: 'Andheri', slug: 'andheri', lat: 19.1197, lon: 72.8464, group: 'Western Suburbs', description: "Andheri's vast sprawl encompasses both the low-lying Versova creek areas prone to severe monsoon waterlogging and the elevated Lokhandwala and Four Bungalows zones with better drainage and airflow. The concentration of commercial towers along the Western Express Highway creates a pronounced urban heat corridor that traps vehicle exhaust and radiant heat." },
        { name: 'Juhu', slug: 'juhu', lat: 19.0988, lon: 72.8267, group: 'Coastal West', description: "Juhu's long sandy beach frontage gives it strong exposure to westerly sea breezes that moderate afternoon heat well into the neighborhood's interior. The low-lying terrain and proximity to the Mithi River floodplain make it extremely vulnerable to tidal surges and monsoon flooding, with standing water raising local humidity significantly." },
        { name: 'Worli', slug: 'worli', lat: 19.0176, lon: 72.8152, group: 'South Mumbai', description: "Worli's coastal promontory jutting into the Arabian Sea gives it exceptional wind exposure, particularly amplified by the Bandra-Worli Sea Link which channels gusty maritime airflow. The rapid proliferation of supertall residential towers has created complex wind tunnel effects at ground level and shadowing patterns that alter heat distribution block by block." },
        { name: 'Powai', slug: 'powai', lat: 19.1176, lon: 72.9060, group: 'Eastern Suburbs', description: "Powai's inland position around the Powai Lake and the surrounding Vikhroli hills creates a distinct microclimate sheltered from Arabian Sea breezes, resulting in hotter daytime temperatures and calmer conditions. The lake's evaporative cooling and remnant green cover from the IIT Bombay campus and Aarey Colony provide measurable nighttime temperature relief compared to surrounding Andheri and Chandivali." },
        { name: 'Kurla', slug: 'kurla', lat: 19.0726, lon: 72.8794, group: 'Central Suburbs', description: "Kurla's dense low-rise informal settlements and heavy commercial traffic create one of Mumbai's most intense urban heat islands, with minimal green cover or ventilation corridors. Proximity to the Mithi River channel brings monsoon flooding risk and post-flood stagnant water that elevates humidity and ground-level temperatures for days after heavy rain events." },
        { name: 'Malad', slug: 'malad', lat: 19.1873, lon: 72.8485, group: 'Western Suburbs', description: "Malad's western coastal fringe along Marve and Aksa beaches receives direct sea breezes, but the eastern commercial core along the Western Express Highway is a dense heat-trapping zone. The proximity to the Sanjay Gandhi National Park's southern edge brings occasional cool katabatic airflow during clear winter nights that is absent in surrounding suburbs." },
        { name: 'Borivali', slug: 'borivali', lat: 19.2307, lon: 72.8567, group: 'Northern Suburbs', description: "Borivali's adjacency to the 104-square-kilometer Sanjay Gandhi National Park gives it Mumbai's most significant green cooling effect, with temperatures 2–4°C below the suburban average during summer afternoons. The park's dense forest cover also influences local rainfall patterns, with Borivali recording higher monsoon precipitation than surrounding areas due to orographic lift from the park's hilly terrain." },
        { name: 'Navi Mumbai', slug: 'navi-mumbai', lat: 19.0330, lon: 73.0297, group: 'Trans-Harbor', description: "Navi Mumbai's planned wide boulevards and generous green setbacks create significantly lower urban heat island intensity compared to the congested island city across the harbor. The extensive mangrove belts along the Thane Creek waterfront act as natural wind breaks and humidity regulators, while the Parsik Hills to the east block continental hot winds during pre-monsoon months." },
        { name: 'Dharavi', slug: 'dharavi', lat: 19.0423, lon: 72.8546, group: 'Central Mumbai', description: "Dharavi's extremely dense informal fabric with narrow lanes, corrugated metal roofing, and minimal open space creates one of the world's most intense localized urban heat islands, with surface temperatures exceeding surrounding areas by 5–7°C during summer. The Mahim Creek and Mithi River boundaries provide no cooling relief, instead contributing stagnant humid air that compounds thermal discomfort." },
        { name: 'Thane', slug: 'thane', lat: 19.2183, lon: 72.9781, group: 'Extended North', description: "Thane's position at the head of the Thane Creek with the Yeoor Hills to the north creates a basin microclimate where monsoon moisture is funneled and trapped, producing some of the Mumbai Metropolitan Region's highest rainfall totals. The creek's tidal influence moderates temperatures along the waterfront Ghodbunder corridor, but rapid high-rise development on former hill slopes has disrupted natural drainage and wind patterns." },
        { name: 'Versova', slug: 'versova', lat: 19.1337, lon: 72.8142, group: 'Coastal West', description: "Versova's position at the mouth of the Malad Creek where it meets the Arabian Sea creates a convergence of marine and estuarine winds that makes it one of western Mumbai's breeziest coastal spots. The low-lying fishing village terrain and proximity to tidal mudflats make it highly vulnerable to storm surges, and the salt-laden air accelerates corrosion while maintaining persistently high relative humidity above 85% even in non-monsoon months." },
      ],
    },

  {
      name: 'Seoul',
      slug: 'seoul',
      country: 'South Korea',
      flag: '🇰🇷',
      lat: 37.5665,
      lon: 126.9780,
      timezone: 'Asia/Seoul',
      description: "Seoul's climate is shaped by its dramatic basin geography — the city sits in a broad valley surrounded by mountains on all sides, with the Han River bisecting it east to west. This topography creates intense summer heat islands in the dense urban core while mountain-adjacent districts enjoy cooler temperatures and better air circulation. Winters bring cold Siberian air that pools in the basin, and the surrounding peaks like Bukhansan (836m) and Gwanaksan (632m) generate significant microclimate variation across the city's neighborhoods.",
      districts: [
        { name: 'Jongno-gu', slug: 'jongno-gu', lat: 37.5735, lon: 126.9790, group: 'Central', description: "Jongno-gu's historic core around Gyeongbokgung Palace benefits from proximity to Bukhansan's southern slopes, which channel cooler mountain air into the district during summer evenings. However, the dense commercial corridors along Jongno street create a pronounced urban heat island that keeps nighttime temperatures 2–3°C above surrounding residential areas." },
        { name: 'Jung-gu', slug: 'jung-gu', lat: 37.5636, lon: 126.9976, group: 'Central', description: "Jung-gu is Seoul's most intensely built downtown core, where Namsan (262m) creates a significant microclimate anchor — its forested slopes cool surrounding blocks by 3–5°C in summer compared to the concrete Myeongdong shopping district at its base. The mountain also deflects prevailing westerly winds, creating sheltered pockets on its eastern lee side." },
        { name: 'Gangnam-gu', slug: 'gangnam-gu', lat: 37.4979, lon: 127.0276, group: 'South of Han', description: "Gangnam-gu's dense cluster of glass-clad high-rises along Teheran-ro creates one of Seoul's most intense urban heat islands, with surface temperatures reaching 5–7°C above surrounding areas in summer. The district's flat terrain south of the Han River receives less natural ventilation than northern districts sheltered by mountains, making humid summer nights particularly oppressive." },
        { name: 'Yongsan-gu', slug: 'yongsan-gu', lat: 37.5326, lon: 126.9906, group: 'Central', description: "Yongsan-gu benefits from dual cooling effects — the Han River's northern bank moderates summer temperatures along the waterfront, while Namsan's western slopes funnel downslope breezes through the district in the evening. The vast open space of the former US military base at Yongsan Garrison creates a notable low-density thermal break in an otherwise dense urban fabric." },
        { name: 'Mapo-gu', slug: 'mapo-gu', lat: 37.5538, lon: 126.9084, group: 'West', description: "Mapo-gu's position along the Han River's north bank gives Hapjeong and Mangwon neighborhoods measurable cooling from river breezes, but the elevated Mapo commercial district inland sees less benefit. The wide Gyeongui Line Forest Park acts as a green wind corridor channeling air from the river northward into otherwise dense residential blocks." },
        { name: 'Songpa-gu', slug: 'songpa-gu', lat: 37.5048, lon: 127.1120, group: 'South East', description: "Songpa-gu's Seokchon Lake and the adjacent Lotte World Tower create a unique microclimate interaction — the lake provides localized evaporative cooling while the 555m supertall tower generates significant wind acceleration at its base. The nearby Olympic Park's large green canopy reduces surrounding surface temperatures by 2–4°C compared to the dense apartment complexes that dominate the district." },
        { name: 'Nowon-gu', slug: 'nowon-gu', lat: 37.6542, lon: 127.0568, group: 'North East', description: "Nowon-gu is nestled against the Suraksan and Bukhansan mountain ranges, making it one of Seoul's coolest districts with winter lows frequently 3–4°C below the city center due to cold air drainage from the peaks. The mountain valleys channel strong northwesterly winds in winter, creating wind-chill conditions significantly harsher than flat southern districts." },
        { name: 'Yeongdeungpo-gu', slug: 'yeongdeungpo-gu', lat: 37.5263, lon: 126.8965, group: 'South West', description: "Yeongdeungpo-gu's industrial heritage left expansive concrete and asphalt surfaces that amplify summer heat, particularly around the Yeouido financial district where glass towers create intense solar reflection. Yeouido's Han River island position provides some waterfront cooling, but the district's flat topography and lack of mountain shelter make it vulnerable to stagnant humid air masses in summer." },
        { name: 'Seodaemun-gu', slug: 'seodaemun-gu', lat: 37.5791, lon: 126.9368, group: 'North West', description: "Seodaemun-gu rises steeply from the city center toward Ansan (296m) and the western ridgeline of Bukhansan, creating significant elevation-based temperature gradients within the district. The hilltop residential areas around Yonsei University experience noticeably cooler summers and earlier autumn foliage than the commercial lowlands near Sinchon station." },
        { name: 'Gangdong-gu', slug: 'gangdong-gu', lat: 37.5301, lon: 127.1238, group: 'East', description: "Gangdong-gu sits at Seoul's eastern edge where the Han River bends south, and the surrounding flat alluvial plain lacks the topographic shielding that protects western districts from cold easterly winds in winter. The district's newer high-rise apartment complexes create wind-tunnel effects along major roads, while scattered remaining agricultural plots act as rare urban cool islands." },
        { name: 'Dobong-gu', slug: 'dobong-gu', lat: 37.6688, lon: 127.0471, group: 'North', description: "Dobong-gu is dominated by the steep granite peaks of Dobongsan (740m), whose forested slopes generate powerful cold air drainage on clear winter nights, making valley-floor neighborhoods among Seoul's coldest locations. Summer brings welcome relief as mountain thermals draw cooler air downslope in the evening, reducing temperatures 4–5°C below the urban core." },
        { name: 'Gwanak-gu', slug: 'gwanak-gu', lat: 37.4784, lon: 126.9516, group: 'South', description: "Gwanak-gu is defined by Gwanaksan (632m), Seoul's prominent southern mountain whose bulk blocks warm southerly air in summer and traps cold pools in the narrow valleys on its northern slopes. The Seoul National University campus on the mountain's lower flanks benefits from forest canopy cooling, while the dense low-rise residential areas in the valley floor experience poor ventilation and summer heat accumulation." },
        { name: 'Eunpyeong-gu', slug: 'eunpyeong-gu', lat: 37.6176, lon: 126.9227, group: 'North West', description: "Eunpyeong-gu's location in a broad valley opening toward Bukhansan National Park gives it some of Seoul's best natural ventilation as mountain air flows down through the Bulgwangcheon stream corridor. However, this same topography funnels cold Siberian air in winter, and the district frequently records temperatures 2–3°C below the Han River corridor." },
        { name: 'Seocho-gu', slug: 'seocho-gu', lat: 37.4837, lon: 127.0324, group: 'South of Han', description: "Seocho-gu spans from the dense Gangnam-adjacent commercial core to the forested northern slopes of Umyeonsan (293m) and Cheonggyesan (618m), creating dramatic microclimate contrasts within a single district. The mountains' green corridors channel cooler air toward the Express Bus Terminal area, but the Banpo riverside zone experiences intense reflected heat from the waterfront apartment towers." },
        { name: 'Seongbuk-gu', slug: 'seongbuk-gu', lat: 37.5894, lon: 127.0167, group: 'North', description: "Seongbuk-gu wraps around the inner slopes of Bukhansan and Bugaksan, with winding hillside neighborhoods that experience 3–4°C cooler summer afternoons than the Jongno flatlands directly below. The dense tree canopy along the old Seoul Fortress Wall trail acts as a natural cooling belt, but the steep terrain creates frost pockets in winter where cold air settles in narrow residential valleys." },
      ],
    },

  {
      name: 'Hong Kong',
      slug: 'hong-kong',
      country: 'Hong Kong',
      flag: '🇭🇰',
      lat: 22.3193,
      lon: 114.1694,
      timezone: 'Asia/Hong_Kong',
      description: "Hong Kong's subtropical climate is dramatically shaped by its mountainous terrain, extensive coastline, and one of the world's densest urban cores. The territory spans Hong Kong Island, the Kowloon Peninsula, the New Territories, and over 200 outlying islands, creating vast microclimate variation between sheltered harbours, exposed ridgelines, and densely built urban canyons. Summer typhoons and monsoon rains interact with steep topography to produce extreme local differences in wind exposure, rainfall totals, and temperature — with urban heat island effects adding 3–5°C to nighttime lows in the densest districts.",
      districts: [
        { name: 'Central', slug: 'central', lat: 22.2810, lon: 114.1585, group: 'Hong Kong Island North', description: "Central's canyon of glass and steel skyscrapers along Victoria Harbour creates one of Asia's most intense urban heat islands, with nighttime temperatures often 4–5°C above rural areas. The dense tower cluster blocks the prevailing summer sea breeze from the harbour, though wind corridors along Queen's Road and Des Voeux Road provide partial ventilation." },
        { name: 'Wan Chai', slug: 'wan-chai', lat: 22.2783, lon: 114.1747, group: 'Hong Kong Island North', description: "Wan Chai's mix of older low-rise tenements and modern waterfront towers creates sharp thermal contrasts within just a few blocks. The harbourfront promenade benefits from direct sea breeze cooling, while the dense interior streets near Johnston Road trap heat and humidity, making it one of the most uncomfortable areas during summer nights." },
        { name: 'Causeway Bay', slug: 'causeway-bay', lat: 22.2800, lon: 114.1860, group: 'Hong Kong Island North', description: "Causeway Bay's extreme commercial density and near-total lack of green space make it a persistent heat hotspot on Hong Kong Island's north shore. Victoria Park provides the only significant cooling oasis in the district, with temperatures measurably lower within and immediately downwind of the park during summer afternoons." },
        { name: 'The Peak', slug: 'the-peak', lat: 22.2759, lon: 114.1455, group: 'Hong Kong Island Upland', description: "Victoria Peak at 552m sits above the urban canopy and regularly experiences temperatures 5–8°C cooler than the harbour districts below, with frequent cloud immersion and fog during spring. The summit is exposed to strong prevailing winds that make it feel significantly cooler year-round, and it often remains above the low-level haze and pollution layer that blankets the harbour." },
        { name: 'Aberdeen', slug: 'aberdeen', lat: 22.2480, lon: 114.1555, group: 'Hong Kong Island South', description: "Aberdeen's sheltered typhoon harbour and south-facing orientation give it a distinctly different wind regime from the north shore — it catches the summer southwest monsoon directly while being shielded from winter northerlies by the island's central ridge. The surrounding hills funnel and accelerate winds through the harbour channel during typhoon approaches." },
        { name: 'Stanley', slug: 'stanley', lat: 22.2180, lon: 114.2113, group: 'Hong Kong Island South', description: "Stanley's exposed southern peninsula position makes it one of Hong Kong Island's windiest and coolest coastal areas, with direct exposure to South China Sea swells and breezes. Summer temperatures run 2–3°C below Central, but the lack of shelter means Stanley bears the full force of typhoon winds and storm surge from the south." },
        { name: 'Tsim Sha Tsui', slug: 'tsim-sha-tsui', lat: 22.2988, lon: 114.1722, group: 'Kowloon', description: "Tsim Sha Tsui's position at the tip of the Kowloon Peninsula gives it harbour exposure on three sides, making it one of the better-ventilated dense urban areas — but the wall of skyscrapers along the waterfront increasingly blocks sea breezes from reaching interior streets. The dense tourist and commercial core around Nathan Road experiences severe nocturnal heat retention." },
        { name: 'Mong Kok', slug: 'mong-kok', lat: 22.3203, lon: 114.1694, group: 'Kowloon', description: "Mong Kok holds one of the highest population densities on Earth, and its tightly packed residential towers, narrow streets, and almost zero vegetation create an extreme urban heat island that rarely cools below 29°C on summer nights. Air stagnation between buildings traps vehicle exhaust and cooking fumes, making street-level air quality among the worst in the territory." },
        { name: 'Sham Shui Po', slug: 'sham-shui-po', lat: 22.3308, lon: 114.1620, group: 'Kowloon', description: "Sham Shui Po's aging building stock with poor insulation and minimal setbacks absorbs and re-radiates heat intensely, consistently recording some of Hong Kong's highest nighttime temperatures. The district's flat, low-lying position behind the Kowloon ridgeline blocks the harbour breeze that benefits waterfront areas just to the south." },
        { name: 'Kowloon City', slug: 'kowloon-city', lat: 22.3282, lon: 114.1875, group: 'Kowloon', description: "Kowloon City's inland position between the former Kai Tak runway and Lion Rock creates a sheltered basin that traps heat during calm summer days. The redeveloped Kai Tak waterfront now channels harbour breezes along the old runway alignment, but the older residential streets to the west remain poorly ventilated." },
        { name: 'Sha Tin', slug: 'sha-tin', lat: 22.3813, lon: 114.1952, group: 'New Territories', description: "Sha Tin sits in a broad river valley surrounded by mountains that shelter it from coastal winds but trap heat and humidity in summer, creating basin-effect temperatures several degrees warmer than nearby hilltops. Winter cold air drainage down the Shing Mun River valley can make overnight temperatures here among the lowest in the urban New Territories." },
        { name: 'Tai Po', slug: 'tai-po', lat: 22.4513, lon: 114.1641, group: 'New Territories', description: "Tai Po's position at the head of Tolo Harbour and the base of Pat Sin Leng range gives it exposure to channelled northeast monsoon winds that funnel down the harbour in winter, producing wind chill effects unusual for subtropical Hong Kong. The surrounding forested hills generate orographic rainfall that makes Tai Po one of the wetter districts during the summer monsoon." },
        { name: 'Tuen Mun', slug: 'tuen-mun', lat: 22.3908, lon: 113.9724, group: 'Western New Territories', description: "Tuen Mun's position in a wide river valley opening to the Pearl River estuary exposes it to maritime influences from the west, including moisture and pollution carried from the Pearl River Delta industrial zone. The valley orientation channels and accelerates winds during typhoon events, and the surrounding Castle Peak hills create strong foehn-like warming effects under certain monsoon conditions." },
        { name: 'Tung Chung', slug: 'tung-chung', lat: 22.2890, lon: 113.9413, group: 'Lantau', description: "Tung Chung sits on Lantau Island's north coast beneath Ngong Ping plateau, where cold katabatic winds drain off the 934m Lantau Peak on clear winter nights, producing some of the territory's lowest urban temperatures. The district's coastal reclamation and proximity to the airport's open runway area expose it to strong, unobstructed southwest monsoon winds in summer." },
        { name: 'Sai Kung', slug: 'sai-kung', lat: 22.3833, lon: 114.2714, group: 'Eastern New Territories', description: "Sai Kung's deeply indented coastline and surrounding country park hills make it one of Hong Kong's most weather-variable districts, with dramatic differences between sheltered inner harbours and exposed headlands just kilometres apart. The volcanic geology and dense forest cover keep temperatures noticeably cooler than the urban core, and the area receives some of Hong Kong's highest annual rainfall totals due to orographic uplift of moist maritime air." },
      ],
    },

  {
      name: 'Rome',
      slug: 'rome',
      country: 'Italy',
      flag: '🇮🇹',
      lat: 41.9028,
      lon: 12.4964,
      timezone: 'Europe/Rome',
      description: "Rome's climate is shaped by its position on the Tiber River plain surrounded by volcanic hills and its relative proximity to the Tyrrhenian Sea, roughly 25 km inland. The city experiences hot, dry summers and mild, wet winters typical of the Mediterranean, but its famous Seven Hills and sprawling urban fabric create significant microclimate variation — low-lying areas near the Tiber are prone to humidity and fog, while hilltop neighborhoods catch cooling breezes. The massive concentration of ancient stone, concrete, and asphalt in the historic core generates one of Italy's most intense urban heat islands, with summer nighttime temperatures often 5–7°C above surrounding countryside.",
      districts: [
        { name: 'Centro Storico', slug: 'centro-storico', lat: 41.8986, lon: 12.4769, group: 'Historic Core', description: "The Centro Storico's dense matrix of stone palazzi, narrow cobblestone streets, and minimal green space creates Rome's most intense urban heat island, with nighttime summer temperatures regularly 5–6°C above suburban areas. The lack of ventilation corridors means sea breezes from the Tyrrhenian rarely penetrate this district, trapping heat and humidity in the ancient street grid." },
        { name: 'Trastevere', slug: 'trastevere', lat: 41.8893, lon: 12.4700, group: 'Historic Core', description: "Trastevere's position on the west bank of the Tiber at the foot of the Janiculum Hill creates a humid microclimate where morning river fog lingers longer than in elevated neighborhoods. The Janiculum's bulk blocks prevailing westerly breezes, leaving Trastevere's narrow medieval alleys poorly ventilated during summer heat waves." },
        { name: 'Testaccio', slug: 'testaccio', lat: 41.8763, lon: 12.4753, group: 'South Central', description: "Testaccio sits in a low-lying area near the Tiber and the ancient river port, where cool, damp air pools on still nights and winter fog is among the densest in Rome. The neighborhood's former slaughterhouse industrial heritage left large paved surfaces that absorb and re-radiate heat, amplifying summer discomfort." },
        { name: 'Prati', slug: 'prati', lat: 41.9120, lon: 12.4613, group: 'Central West', description: "Prati's orderly grid of wide boulevards between the Vatican walls and the Tiber provides better airflow than most central neighborhoods, channeling occasional westerly breezes toward the river. However, its flat, low-lying position on former Tiber floodplain makes it one of Rome's most humid districts, with persistent morning fog in autumn and winter." },
        { name: 'Esquilino', slug: 'esquilino', lat: 41.8955, lon: 12.5030, group: 'Central East', description: "Esquilino occupies one of Rome's original seven hills, giving it a slight elevation advantage that improves air circulation compared to the Tiber valley below. Despite this, the dense 19th-century residential blocks around Piazza Vittorio and proximity to Termini station's vast asphalt surfaces create a significant localized heat island." },
        { name: 'Monteverde', slug: 'monteverde', lat: 41.8754, lon: 12.4520, group: 'Southwest Hills', description: "Monteverde's elevated position on the Janiculum ridge, between 50 and 80 meters above the Tiber, gives it access to Tyrrhenian sea breezes that cool summer evenings noticeably earlier than in the valley below. The abundant tree cover from Villa Doria Pamphilj — Rome's largest park — provides substantial evapotranspiration cooling that lowers local temperatures by 2–3°C compared to adjacent built-up areas." },
        { name: 'EUR', slug: 'eur', lat: 41.8314, lon: 12.4672, group: 'South', description: "EUR's Fascist-era monumental architecture features wide boulevards and open plazas with marble and travertine surfaces that reflect intense solar radiation in summer. The district's artificial lake and surrounding parkland provide some evaporative cooling, but the sparse tree canopy and expansive light-colored paving create harsh glare and heat during peak hours." },
        { name: 'San Giovanni', slug: 'san-giovanni', lat: 41.8857, lon: 12.5082, group: 'Central East', description: "San Giovanni sits on the broad Caelian Hill slope, where its moderate elevation provides marginally better ventilation than the Tiber lowlands but not enough to escape Rome's summer heat dome. The district's dense postwar apartment blocks with dark roofing and limited setbacks store significant thermal mass, keeping overnight temperatures elevated." },
        { name: 'Parioli', slug: 'parioli', lat: 41.9270, lon: 12.4882, group: 'North', description: "Parioli's affluent tree-lined streets and proximity to the vast Villa Borghese and Villa Ada parklands create one of Rome's coolest and most pleasant microclimates. The neighborhood's position on gentle northern hills allows it to intercept cooler air draining from the Monti Parioli ridge, while the dense canopy of umbrella pines and plane trees reduces peak summer temperatures significantly." },
        { name: 'Flaminio', slug: 'flaminio', lat: 41.9310, lon: 12.4720, group: 'North', description: "Flaminio stretches along the Tiber's east bank in a narrow valley between the Parioli hills and Monte Mario, creating a natural wind corridor that channels breezes along the river. This funnel effect provides reliable ventilation in summer but also concentrates cold, damp air in winter, making Flaminio one of Rome's foggier northern neighborhoods." },
        { name: 'Monte Mario', slug: 'monte-mario', lat: 41.9380, lon: 12.4440, group: 'Northwest Hills', description: "At 139 meters, Monte Mario is Rome's highest hill and experiences distinctly cooler temperatures than the city center, with summer highs typically 3–4°C lower and more frequent breezes from the northwest. The hill's extensive nature reserve and pine forest create a microclimate closer to the surrounding Lazio countryside than to urban Rome below." },
        { name: 'Garbatella', slug: 'garbatella', lat: 41.8620, lon: 12.4870, group: 'South Central', description: "Garbatella's distinctive 1920s garden-city layout with low-rise buildings, interior courtyards, and abundant communal green spaces provides natural cooling that neighboring denser districts lack. The planned ventilation gaps between building clusters allow airflow from the nearby Ostiense valley, though proximity to former industrial gasworks and rail yards adds residual thermal mass." },
        { name: 'San Lorenzo', slug: 'san-lorenzo', lat: 41.8970, lon: 12.5170, group: 'East', description: "San Lorenzo's compact 19th-century workers' housing and proximity to the massive rail infrastructure of Roma Termini and Tiburtina create a pronounced heat island intensified by steel tracks and dark roofing. The flat terrain east of the historic hills receives little benefit from topographic breezes, and the scarcity of parks leaves few refuges from summer heat." },
        { name: 'Appio-Latino', slug: 'appio-latino', lat: 41.8720, lon: 12.5150, group: 'Southeast', description: "Appio-Latino spreads across the gentle slopes of the ancient Appian Way corridor, where the open parkland of the Caffarella valley and Parco degli Acquedotti creates a green wedge that channels cooler countryside air into the urban fabric. The contrast between the leafy archaeological park zones and the dense residential blocks along Via Appia Nuova produces hyperlocal temperature differences of up to 4°C on summer afternoons." },
        { name: 'Ostiense', slug: 'ostiense', lat: 41.8650, lon: 12.4770, group: 'South Central', description: "Ostiense's post-industrial landscape of former power stations, warehouses, and rail yards along the Tiber creates extensive dark, heat-absorbing surfaces that amplify summer temperatures in this low-lying river district. The ongoing conversion to nightlife and university use has increased impervious surface area, though the Tiber's proximity adds humidity that makes summer heat feel more oppressive than thermometers alone suggest." },
      ],
    },

  {
      name: 'Berlin',
      slug: 'berlin',
      country: 'Germany',
      flag: '🇩🇪',
      lat: 52.5200,
      lon: 13.4050,
      timezone: 'Europe/Berlin',
      description: "Berlin's continental climate is moderated by its extensive network of rivers, lakes, and urban forests that cover nearly a third of the city's area. The flat glacial landscape of the North European Plain means wind flows largely unimpeded across the city, but dense inner-city districts create significant urban heat islands while the surrounding forests and waterways of the Havel and Spree rivers provide notable cooling corridors. Winters can be harsh with cold easterly winds from the Eurasian steppe, while summers bring increasing heat extremes that are amplified in the heavily built-up central districts.",
      districts: [
        { name: 'Mitte', slug: 'mitte', lat: 52.5200, lon: 13.4050, group: 'Central', description: "Mitte's dense concentration of stone and concrete government buildings, wide boulevards, and minimal tree canopy creates Berlin's most intense urban heat island, with nighttime temperatures running 4–6°C above suburban areas. The Spree River corridor provides some localized cooling but the effect is limited by the heavy building mass along its banks." },
        { name: 'Kreuzberg', slug: 'kreuzberg', lat: 52.4895, lon: 13.4030, group: 'Central South', description: "Kreuzberg's tightly packed 19th-century tenement blocks with enclosed courtyards trap heat and limit airflow, making it one of Berlin's warmest neighborhoods in summer. The Landwehr Canal provides a modest cooling corridor, but the district's high building density and extensive impervious surfaces amplify heat retention well into the night." },
        { name: 'Prenzlauer Berg', slug: 'prenzlauer-berg', lat: 52.5388, lon: 13.4244, group: 'Northeast', description: "Prenzlauer Berg's gentle hilltop position — one of Berlin's few elevated areas — gives it slightly better air circulation than the surrounding flatlands. However, the dense Wilhelmine-era block development with narrow streets and dark facades creates substantial heat storage, offset only partially by the mature street trees lining its boulevards." },
        { name: 'Charlottenburg', slug: 'charlottenburg', lat: 52.5163, lon: 13.3040, group: 'West', description: "Charlottenburg benefits from the large cooling effect of the Tiergarten to its east and the Schlosspark to its north, which together create a green ventilation corridor through western Berlin. The mix of wide Wilhelmine avenues and generous tree canopy moderates summer heat, though the Kurfürstendamm commercial strip retains more heat due to its dense retail frontages." },
        { name: 'Friedrichshain', slug: 'friedrichshain', lat: 52.5136, lon: 13.4538, group: 'East', description: "Friedrichshain's mix of GDR-era Plattenbau high-rises and renovated Altbau blocks creates uneven wind patterns — the tower blocks channel and accelerate winds while low-rise streets remain sheltered. The Spree riverbank and Volkspark Friedrichshain provide important cool-air generation zones, dropping local temperatures by 2–3°C compared to surrounding built-up blocks." },
        { name: 'Neukölln', slug: 'neukoelln', lat: 52.4812, lon: 13.4350, group: 'South', description: "Northern Neukölln's extremely dense Gründerzeit building fabric with minimal green space makes it one of Berlin's most heat-stressed neighborhoods, regularly recording the city's highest overnight minimum temperatures. The Tempelhofer Feld — the vast open former airfield — acts as a massive cold-air reservoir on its western border, generating cool breezes that reach adjacent streets on calm summer evenings." },
        { name: 'Schöneberg', slug: 'schoeneberg', lat: 52.4840, lon: 13.3530, group: 'Central South', description: "Schöneberg occupies a transitional zone between Berlin's dense inner city and the greener western suburbs, with building density decreasing notably toward the south. The neighborhood benefits from cool-air drainage off the Insulaner hill and the green corridor of the Südgelände nature park, which channel fresh air into the otherwise compact urban fabric." },
        { name: 'Wedding', slug: 'wedding', lat: 52.5500, lon: 13.3500, group: 'North', description: "Wedding's industrial heritage left behind large areas of impervious surfaces and warehouse complexes that absorb and radiate heat. The Panke stream corridor and Volkspark Rehberge serve as critical cool-air arteries, but the neighborhood's flat topography and surrounding dense development limit effective ventilation on still summer days." },
        { name: 'Spandau', slug: 'spandau', lat: 52.5352, lon: 13.2000, group: 'West Outer', description: "Spandau's position at the confluence of the Spree and Havel rivers gives it Berlin's strongest waterside cooling effect, with summer temperatures regularly 3–4°C below central districts. The extensive Spandauer Forst to the north generates cool forest air that flows into the built-up areas during evening hours, making frost more frequent here in winter as well." },
        { name: 'Köpenick', slug: 'koepenick', lat: 52.4435, lon: 13.5808, group: 'Southeast', description: "Köpenick is Berlin's largest and greenest district, dominated by the Müggelsee — the city's biggest lake — and surrounding extensive forests that create a distinctly cooler and more humid microclimate. The large water body moderates temperature extremes year-round, delaying spring warming but keeping autumn temperatures milder, while morning fog over the lake is common from September through November." },
        { name: 'Grunewald', slug: 'grunewald', lat: 52.4780, lon: 13.2620, group: 'Southwest', description: "The Grunewald forest is Berlin's primary fresh-air generator, producing cool and oxygen-rich air that flows eastward into the inner city through green corridors. Residential areas adjacent to the forest experience summer temperatures 5–7°C below inner-city peaks, but the tree canopy and sandy soils also create higher humidity and more frequent ground frost in winter." },
        { name: 'Tempelhof', slug: 'tempelhof', lat: 52.4700, lon: 13.3990, group: 'South', description: "The former Tempelhof Airport's 386-hectare open grassland creates one of Europe's largest urban cold-air production zones, generating measurable cooling winds that reach surrounding neighborhoods on summer evenings. The vast unobstructed expanse is also one of Berlin's windiest locations, fully exposed to prevailing westerly and occasional harsh easterly winter winds." },
        { name: 'Pankow', slug: 'pankow', lat: 52.5700, lon: 13.4100, group: 'North', description: "Pankow's suburban character with detached houses, allotment gardens, and the Panke river valley gives it a noticeably cooler summer climate than inner-city districts just to its south. The lower building density allows cold air to pool in the Panke valley on clear winter nights, creating frequent frost hollows and localized fog that the denser city center avoids." },
        { name: 'Dahlem', slug: 'dahlem', lat: 52.4570, lon: 13.2880, group: 'Southwest', description: "Dahlem's villa-lined streets, generous garden plots, and proximity to the Grunewald forest and Botanischer Garten create Berlin's most consistently cool residential microclimate. The neighborhood hosts one of Germany's oldest weather stations, which has documented that Dahlem averages 2–3°C cooler than Mitte in summer and records significantly more frost days in winter." },
        { name: 'Lichtenberg', slug: 'lichtenberg', lat: 52.5145, lon: 13.5000, group: 'East', description: "Lichtenberg's extensive GDR-era Plattenbau estates with wide spacing between tower blocks allow better airflow than Berlin's dense 19th-century neighborhoods, but the vast concrete surfaces create significant radiative heat. The Tierpark Berlin and surrounding green spaces in the south provide localized cooling, while the flat open rail yards channel easterly winds directly through the district in winter." },
      ],
    },

  {
      name: 'Madrid',
      slug: 'madrid',
      country: 'Spain',
      flag: '🇪🇸',
      lat: 41.3874,
      lon: -3.7038,
      timezone: 'Europe/Madrid',
      description: "Madrid sits on the central Iberian plateau at approximately 650m elevation, making it one of Europe's highest capital cities with a continental Mediterranean climate of extreme temperature swings. The Sierra de Guadarrama to the northwest acts as a barrier to Atlantic weather systems while channeling cold winter winds into the city. Summers are intensely hot and dry on the plateau, but elevation differences across the city and the Manzanares river valley create meaningful microclimate variation between districts.",
      districts: [
        { name: 'Sol-Gran Vía', slug: 'sol-gran-via', lat: 41.3868, lon: -3.7024, group: 'Centro', description: "Sol-Gran Vía forms Madrid's densest commercial core, where continuous stone and granite facades, narrow streets, and minimal vegetation create the city's most intense urban heat island — nighttime temperatures can run 5–6°C above suburban areas. The canyon-like streets of the old center limit wind penetration, trapping heat and pollution during summer anticyclonic conditions." },
        { name: 'Lavapiés', slug: 'lavapies', lat: 41.3823, lon: -3.7010, group: 'Centro', description: "Lavapiés occupies a south-facing slope below the historic center, where solar exposure and extremely dense low-rise building fabric amplify summer heat accumulation. The neighborhood's narrow streets and lack of significant green space make it one of Madrid's hottest areas during heatwaves, with poor nocturnal cooling." },
        { name: 'Malasaña', slug: 'malasana', lat: 41.3949, lon: -3.7057, group: 'Centro', description: "Malasaña's 19th-century grid of narrow streets and six-story buildings creates deep urban canyons that provide daytime shade but trap heat overnight. Its position slightly north of Gran Vía gives it marginal exposure to cool northwesterly Sierra winds that occasionally funnel down Calle Fuencarral." },
        { name: 'Retiro', slug: 'retiro', lat: 41.3841, lon: -3.6827, group: 'Central East', description: "The 125-hectare Parque del Retiro acts as Madrid's primary green lung, creating a measurable cooling island that lowers surrounding temperatures by 2–4°C during summer afternoons through evapotranspiration. The park's large artificial lake and mature tree canopy generate cool air that drains into adjacent residential streets, particularly noticeable on calm summer evenings." },
        { name: 'Salamanca', slug: 'salamanca', lat: 41.3935, lon: -3.6796, group: 'Central East', description: "Salamanca's wide orthogonal boulevards and uniform six-story stone buildings create an efficient wind corridor system that channels breezes from the Retiro park and northeast. However, the extensive use of granite and limestone in facades and the minimal tree cover on many streets contribute to significant heat retention during Madrid's prolonged summer heatwaves." },
        { name: 'Chamberí', slug: 'chamberi', lat: 41.4012, lon: -3.7052, group: 'North Central', description: "Chamberí sits on a gentle rise north of the old city, giving it slightly better air circulation than the lower-lying centro districts. The neighborhood's broad streets like Santa Engracia act as ventilation corridors for Sierra de Guadarrama breezes, but dense residential blocks still generate a pronounced urban heat island effect." },
        { name: 'Chamartín', slug: 'chamartin', lat: 41.4587, lon: -3.6771, group: 'North', description: "Chamartín's position in Madrid's northern expansion zone gives it greater exposure to cold northwesterly winds descending from the Sierra de Guadarrama, making winters noticeably harsher than in the sheltered centro. The Paseo de la Castellana acts as a major wind corridor that accelerates these Sierra-channeled breezes through the district." },
        { name: 'Moncloa-Aravaca', slug: 'moncloa-aravaca', lat: 41.4100, lon: -3.7318, group: 'Northwest', description: "Moncloa-Aravaca benefits from the extensive green spaces of Casa de Campo and Ciudad Universitaria, which together form Madrid's largest cooling zone and significantly moderate summer extremes. The district's elevated western position makes it the first to receive moisture-laden Atlantic fronts that clear the Guadarrama, bringing earlier rainfall than eastern districts." },
        { name: 'Latina', slug: 'latina', lat: 41.3865, lon: -3.7336, group: 'Southwest', description: "Latina descends steeply toward the Manzanares river valley, creating significant elevation variation within the district — lower areas near the river experience cold air pooling on calm winter nights and morning frost. The recently renaturalized Madrid Río park along the Manzanares provides riparian cooling and humidity that contrasts sharply with the arid plateau conditions above." },
        { name: 'Carabanchel', slug: 'carabanchel', lat: 41.3725, lon: -3.7418, group: 'Southwest', description: "Carabanchel's position on the south-facing slopes above the Manzanares valley exposes it to intense solar radiation during Madrid's long summer days, making it consistently one of the city's hottest districts. Limited green infrastructure and extensive mid-20th-century concrete housing blocks amplify heat storage, with poor nocturnal cooling due to the thermal mass of dense social housing developments." },
        { name: 'Usera', slug: 'usera', lat: 41.3575, lon: -3.7100, group: 'South', description: "Usera occupies low-lying terrain south of the Manzanares where cold air drainage from the plateau concentrates on still winter nights, producing some of Madrid's lowest urban temperatures and frequent frost. In summer, the flat topography and lack of significant tree cover leave the district fully exposed to the intense solar radiation of the central meseta." },
        { name: 'Vallecas', slug: 'vallecas', lat: 41.3575, lon: -3.6618, group: 'Southeast', description: "Vallecas sits in a broad valley depression southeast of the city center, where temperature inversions trap cold air and pollution during winter, creating Madrid's most frequent fog events. The southeastern exposure and low elevation make summers brutally hot, with temperatures regularly exceeding the city average by 1–2°C due to the rain shadow effect of the central urban mass." },
        { name: 'Hortaleza', slug: 'hortaleza', lat: 41.4685, lon: -3.6399, group: 'Northeast', description: "Hortaleza's position on the open northeastern plateau exposes it to unobstructed continental winds and wider diurnal temperature ranges than the sheltered city center. Lower building density and proximity to the Valdebebas park and airport open spaces allow more effective radiative cooling at night, making frost significantly more common here than in central Madrid." },
        { name: 'Fuencarral-El Pardo', slug: 'fuencarral-el-pardo', lat: 41.4925, lon: -3.7340, group: 'Far North', description: "Fuencarral-El Pardo encompasses the vast Monte de El Pardo forest, a 16,000-hectare Mediterranean woodland that acts as a massive regional climate buffer and is the primary source of cool air drainage into northern Madrid on summer evenings. The district's higher elevation and extensive tree cover make it 3–5°C cooler than the city center in summer, while winter mornings frequently see ground frost and mist in the Manzanares valley floor." },
        { name: 'San Blas-Canillejas', slug: 'san-blas-canillejas', lat: 41.4317, lon: -3.6194, group: 'East', description: "San Blas-Canillejas occupies the eastern plateau fringe where Madrid transitions to open steppe, exposing the district to strong unimpeded easterly winds and extreme continentality. The proximity to Barajas airport's vast paved surfaces contributes to localized heat effects, while the flat open terrain allows rapid radiative cooling that produces some of the metropolitan area's sharpest day-night temperature swings." },
      ],
    },

  {
      name: 'Vienna',
      slug: 'vienna',
      country: 'Austria',
      flag: '🇦🇹',
      lat: 48.2082,
      lon: 16.3738,
      timezone: 'Europe/Vienna',
      description: "Vienna's climate sits at the crossroads of oceanic and continental influences, with the Wienerwald (Vienna Woods) to the west acting as a natural barrier against Atlantic weather systems. The Danube River and its canal create cooling corridors through the city, while the flat Pannonian Plain to the east channels hot, dry air in summer and bitter cold winds in winter. Elevation differences between the western hillside vineyards and the low-lying eastern floodplains produce temperature variations of up to 5°C across the city.",
      districts: [
        { name: 'Innere Stadt', slug: 'innere-stadt', lat: 48.2082, lon: 16.3738, group: 'Central', description: "Vienna's historic first district is the city's most intense urban heat island — dense stone architecture from the Habsburg era retains solar energy and narrow streets limit airflow, pushing nighttime temperatures 3–4°C above outer districts. The Ringstraße's wide boulevard provides the only significant wind corridor, channeling Danube breezes into the otherwise stagnant core." },
        { name: 'Leopoldstadt', slug: 'leopoldstadt', lat: 48.2163, lon: 16.3942, group: 'Danube', description: "Leopoldstadt is bounded by the Danube Canal and the Danube proper, making it Vienna's most water-influenced district with noticeably higher humidity and morning fog frequency. The vast Prater park — over 6 km² of woodland — acts as a massive green lung that cools surrounding streets by 2–3°C on summer afternoons." },
        { name: 'Landstraße', slug: 'landstrasse', lat: 48.1964, lon: 16.3944, group: 'Central South', description: "Landstraße's mix of dense Gründerzeit apartment blocks and the expansive Belvedere gardens creates sharp microclimate contrasts within a few hundred meters. The Danube Canal along its northern edge provides a modest cooling breeze, but the built-up areas around Erdberg's former industrial zones retain significant heat." },
        { name: 'Wieden', slug: 'wieden', lat: 48.1920, lon: 16.3680, group: 'Central South', description: "Wieden is one of Vienna's smallest and most densely built districts, where tall 19th-century apartment blocks create deep street canyons that trap heat and limit ventilation. Proximity to the Karlsplatz open space and the Naschmarkt corridor provides localized relief, but the district consistently records some of the city's highest overnight minimum temperatures." },
        { name: 'Döbling', slug: 'doebling', lat: 48.2536, lon: 16.3493, group: 'Western Hills', description: "Döbling climbs into the Wienerwald foothills with elevations reaching over 500m at Kahlenberg and Leopoldsberg, making it Vienna's coolest district with summer temperatures 4–6°C below the city center. The hillside vineyards and forests generate katabatic winds that flow downslope on clear evenings, delivering cool, fresh air to the neighborhoods below." },
        { name: 'Favoriten', slug: 'favoriten', lat: 48.1649, lon: 16.3821, group: 'South', description: "Favoriten is Vienna's most populous district, and its dense post-war housing blocks combined with extensive railway infrastructure and commercial zones create a pronounced urban heat island south of the historic core. The Laaer Berg hill provides some elevation-driven cooling in its southern reaches, but the flat, heavily sealed northern sections suffer from poor nighttime heat dissipation." },
        { name: 'Floridsdorf', slug: 'floridsdorf', lat: 48.2565, lon: 16.4003, group: 'Transdanubian', description: "Floridsdorf's position on the flat Marchfeld plain north of the Danube exposes it to strong Pannonian winds from the east, making it one of Vienna's windiest and most continental-feeling districts. The Alte Donau lake system moderates local temperatures slightly, but winter cold pools on the flat terrain and frost occurs earlier and more frequently than in the city center." },
        { name: 'Donaustadt', slug: 'donaustadt', lat: 48.2353, lon: 16.4651, group: 'Transdanubian', description: "Donaustadt is Vienna's largest district by area, stretching across the Danube floodplain with vast open agricultural land to the east that allows unobstructed continental air masses to penetrate. The Neue Donau and Alte Donau waterways create localized cooling and elevated humidity, while the Lobau wetland forest acts as a natural air conditioning zone along the district's southern edge." },
        { name: 'Ottakring', slug: 'ottakring', lat: 48.2116, lon: 16.3118, group: 'Western Hills', description: "Ottakring transitions sharply from dense working-class housing along the Gürtel belt road to Wienerwald forest on Wilhelminenberg hill in its western half. The forested slopes channel cool evening air into the built-up lowlands, but the eastern Gürtel corridor traps traffic-generated heat and pollution, creating a stark thermal divide within the district." },
        { name: 'Hietzing', slug: 'hietzing', lat: 48.1781, lon: 16.2990, group: 'Western Hills', description: "Hietzing benefits from the vast Schönbrunn Palace gardens and the adjacent Lainzer Tiergarten nature reserve, together forming one of the largest green and forested areas within any European capital. These green spaces generate measurably cooler air that flows into surrounding residential streets, and the Wienerwald's western sheltering effect reduces exposure to strong Atlantic-driven storms." },
        { name: 'Simmering', slug: 'simmering', lat: 48.1719, lon: 16.4338, group: 'South East', description: "Simmering's flat topography along the old Danube floodplain and its legacy of heavy industry and logistics infrastructure make it one of Vienna's warmest districts on summer days. The Zentralfriedhof — one of Europe's largest cemeteries — provides an unexpected green island effect, while eastern exposure to the Pannonian Plain brings dry, hot air in summer and biting cold in winter." },
        { name: 'Brigittenau', slug: 'brigittenau', lat: 48.2327, lon: 16.3719, group: 'Danube', description: "Brigittenau is almost entirely surrounded by water — the Danube Canal to the south and the Danube to the north — creating a natural humidity corridor with frequent morning fog in autumn and winter. Dense residential blocks from the early 20th century limit the water's cooling potential, and the low-lying terrain makes the district susceptible to cold air pooling during temperature inversions." },
        { name: 'Mariahilf', slug: 'mariahilf', lat: 48.1963, lon: 16.3527, group: 'Central', description: "Mariahilf's position on a gentle slope between the Wiental valley and the inner city creates a subtle but measurable wind corridor along the Wien River channel that provides summer ventilation. The densely built commercial and residential fabric around Mariahilfer Straße — Vienna's busiest shopping street — generates significant pedestrian-level heat from sealed surfaces and building heat emissions." },
        { name: 'Hernals', slug: 'hernals', lat: 48.2275, lon: 16.3207, group: 'Western Hills', description: "Hernals stretches from the urban Gürtel belt into the Wienerwald, with its upper reaches around Hameau and Neuwaldegg sitting in dense forest that keeps summer temperatures markedly lower than the valley floor. Cold air drainage from these wooded slopes creates late frost pockets in the transition zone, while the lower urban areas near the Gürtel experience typical inner-city heat island conditions." },
        { name: 'Liesing', slug: 'liesing', lat: 48.1331, lon: 16.3058, group: 'South West', description: "Liesing sits at Vienna's southwestern edge where the Wienerwald meets the suburban fringe, and its mix of low-density housing, industrial parks, and remnant agricultural land creates a patchwork of microclimates. The Liesing stream valley acts as a cold air corridor that channels cool forest air from the west, but scattered commercial zones with large sealed surfaces create localized heat spots." },
      ],
    },

  {
      name: 'Prague',
      slug: 'prague',
      country: 'Czech Republic',
      flag: '🇨🇿',
      lat: 50.0755,
      lon: 14.4378,
      timezone: 'Europe/Prague',
      description: "Prague's continental climate is profoundly shaped by the Vltava River valley that bisects the city and the surrounding ring of hills and plateaus. The river corridor channels winds and generates fog, while elevation differences of over 200 meters between the valley floor and hilltop neighborhoods create distinct temperature gradients. Winters can see persistent temperature inversions that trap cold air and smog in the river basin, while hilltop districts like Petřín and Žižkov ridge enjoy clearer, warmer conditions above the fog layer.",
      districts: [
        { name: 'Staré Město', slug: 'stare-mesto', lat: 50.0870, lon: 14.4208, group: 'Historic Center', description: "Staré Město's dense medieval street network with narrow lanes and heavy stone buildings creates a pronounced urban heat island at the heart of the Vltava basin. Proximity to the river brings frequent morning fog in autumn and winter, while the lack of green space and poor ventilation keep summer nighttime temperatures 2–3°C above the city average." },
        { name: 'Malá Strana', slug: 'mala-strana', lat: 50.0880, lon: 14.4040, group: 'Historic Center', description: "Malá Strana sits in a sheltered pocket between Petřín Hill and Prague Castle ridge, creating a distinctive wind shadow that traps warm air in summer and cold fog in winter. The baroque palaces with large gardens provide localized cooling, but the enclosed valley position makes it one of Prague's most fog-prone neighborhoods." },
        { name: 'Hradčany', slug: 'hradcany', lat: 50.0910, lon: 14.3965, group: 'Castle District', description: "Hradčany's elevated position on the castle ridge at roughly 300m keeps it above the worst of Prague's river valley fog and temperature inversions. The exposed hilltop catches westerly winds that lower perceived temperatures year-round, and the extensive castle gardens and Strahov monastery grounds provide significant green cooling." },
        { name: 'Žižkov', slug: 'zizkov', lat: 50.0870, lon: 14.4500, group: 'East Inner', description: "Žižkov's hilly terrain with its prominent ridge and the Vítkov hill park creates sharp microclimate gradients over short distances — hilltop areas are windier and cooler while the dense residential streets below trap heat. The neighborhood's high building density and limited tree canopy contribute to one of Prague's strongest east-side urban heat islands." },
        { name: 'Vinohrady', slug: 'vinohrady', lat: 50.0753, lon: 14.4437, group: 'East Inner', description: "Vinohrady occupies a gentle south-facing slope historically used for vineyards, giving it excellent solar exposure and slightly warmer average temperatures than surrounding districts. The wide tree-lined avenues and Riegrovy Sady park provide meaningful canopy cooling, but the continuous blocks of apartment buildings retain heat well into the night." },
        { name: 'Nové Město', slug: 'nove-mesto', lat: 50.0780, lon: 14.4260, group: 'Historic Center', description: "Nové Město's broad boulevards designed by Charles IV create effective wind corridors that channel Vltava valley breezes through the city center. However, the extensive paved surfaces around Wenceslas Square and the National Museum area generate significant heat island effects, making it one of Prague's hottest districts during summer heatwaves." },
        { name: 'Smíchov', slug: 'smichov', lat: 50.0690, lon: 14.4020, group: 'West Bank', description: "Smíchov sits in a natural amphitheater formed by the Vltava bend and surrounding hills, which traps cold air during winter inversions and concentrates summer heat. Its industrial heritage left large impervious surfaces that amplify heat, though the riverside promenade and proximity to Kinský Garden on Petřín provide some relief." },
        { name: 'Holešovice', slug: 'holesovice', lat: 50.1050, lon: 14.4350, group: 'North Inner', description: "Holešovice occupies a Vltava river meander that makes it one of Prague's most flood-prone and fog-susceptible districts. The large Stromovka park — Prague's oldest — creates a measurable cooling island that lowers surrounding temperatures by 2–4°C in summer, but the former industrial zones along the river retain heat and reduce air quality during inversions." },
        { name: 'Karlín', slug: 'karlin', lat: 50.0920, lon: 14.4510, group: 'East Inner', description: "Karlín's position on the Vltava floodplain makes it Prague's lowest-lying major district, where cold dense air settles during winter nights creating persistent frost pockets. Rapid redevelopment with glass-clad office buildings has introduced new wind tunneling effects along Rohanské nábřeží, while the Vítkov hill to the south blocks afternoon sun in winter." },
        { name: 'Dejvice', slug: 'dejvice', lat: 50.1005, lon: 14.3920, group: 'West Upper', description: "Dejvice sits on an elevated plateau northwest of the castle at around 280m, giving it consistent wind exposure from prevailing westerlies and noticeably cooler temperatures than the valley floor. The wide planned avenues radiate from Vítězné náměstí, creating effective ventilation corridors that reduce summer heat buildup compared to the denser historic core." },
        { name: 'Bubeneč', slug: 'bubenec', lat: 50.1070, lon: 14.4100, group: 'North Inner', description: "Bubeneč benefits enormously from the combined cooling effect of Stromovka park and the adjacent Royal Game Reserve, which together form one of Central Europe's largest urban green spaces. The embassy quarter's low building density and mature tree canopy keep summer temperatures significantly below the city average, though river proximity brings dense autumn fog." },
        { name: 'Troja', slug: 'troja', lat: 50.1170, lon: 14.4180, group: 'North Outer', description: "Troja's deep river valley position between steep vineyard-covered slopes creates a sheltered microclimate historically exploited for viticulture. The valley traps warm air during calm conditions making it one of Prague's mildest spots, but the same topography concentrates cold air drainage in winter and makes Troja exceptionally frost-prone on clear nights." },
        { name: 'Břevnov', slug: 'brevnov', lat: 50.0840, lon: 14.3720, group: 'West Upper', description: "Břevnov's position on the western plateau above the Vltava valley exposes it to Atlantic weather systems arriving from the west before they descend into the city basin. The Ladronka park and the historic monastery gardens provide green cooling corridors, and the neighborhood's moderate density allows better air circulation than the compact historic core." },
        { name: 'Modřany', slug: 'modrany', lat: 50.0130, lon: 14.4180, group: 'South Outer', description: "Modřany lies in a southern stretch of the Vltava valley flanked by forested hillsides that channel river breezes and create a natural wind corridor. The surrounding Modřanská rokle canyon and Cholupický vrch hill generate significant cold air drainage on clear nights, making winter morning temperatures here among the lowest in metropolitan Prague." },
        { name: 'Letňany', slug: 'letnany', lat: 50.1280, lon: 14.5140, group: 'North East Outer', description: "Letňany sits on the open northern plain beyond Prague's protective ring of hills, fully exposed to cold northeasterly winds in winter that make it one of the city's windiest and coldest residential areas. The flat terrain with large commercial zones and the former airfield creates minimal wind shelter, and the absence of the Vltava's moderating influence amplifies the continental temperature extremes." },
      ],
    },

  {
      name: 'Lisbon',
      slug: 'lisbon',
      country: 'Portugal',
      flag: '🇵🇹',
      lat: 38.7223,
      lon: -9.1393,
      timezone: 'Europe/Lisbon',
      description: "Lisbon's climate is shaped by its position on the north bank of the wide Tagus estuary and its famously hilly terrain — seven main hills create dramatic elevation differences across short distances. The city enjoys a Mediterranean climate with warm, dry summers and mild, wet winters, but the Tagus estuary acts as a massive thermal regulator, channeling Atlantic breezes deep into the urban core. Coastal fog, locally known as 'cacimbo,' frequently rolls in from the Atlantic, particularly affecting western and riverside districts while hilltop neighborhoods bask in sunshine above the marine layer.",
      districts: [
        { name: 'Baixa', slug: 'baixa', lat: 38.7114, lon: -9.1390, group: 'Downtown', description: "Baixa occupies the flat valley floor between Lisbon's São Jorge and São Roque hills, making it a natural wind corridor that channels Tagus estuary breezes northward through its rigid Pombaline grid. The wide streets and uniform stone facades create a moderate urban heat island, though river proximity keeps summer highs 2–3°C below hilltop districts shielded from the breeze." },
        { name: 'Alfama', slug: 'alfama', lat: 38.7119, lon: -9.1302, group: 'Historic Center', description: "Alfama's labyrinthine medieval streets and tightly packed buildings on the south-facing slope below São Jorge Castle create deep shade but extremely poor ventilation. The steep terrain facing the Tagus captures direct morning sun and radiated heat from limestone walls, making it one of Lisbon's warmest neighborhoods on still summer nights." },
        { name: 'Bairro Alto', slug: 'bairro-alto', lat: 38.7137, lon: -9.1455, group: 'Historic Center', description: "Bairro Alto's hilltop position at roughly 80m elevation exposes it to Atlantic winds that sweep across from the west, providing natural cooling that the lower Baixa lacks. The dense historic fabric of narrow streets retains daytime heat but the elevated, exposed position means temperatures drop quickly after sunset." },
        { name: 'Belém', slug: 'belem', lat: 38.6966, lon: -9.2063, group: 'Western Waterfront', description: "Belém's wide-open riverside esplanade and proximity to the Tagus mouth give it Lisbon's most maritime-influenced microclimate, with persistent Atlantic breezes and frequent morning fog. The expansive green spaces of Jardim de Belém and the Jerónimos monastery grounds provide significant cooling, keeping summer temperatures 3–4°C below dense inland neighborhoods." },
        { name: 'Parque das Nações', slug: 'parque-das-nacoes', lat: 38.7633, lon: -9.0946, group: 'Eastern Waterfront', description: "Parque das Nações' modern waterfront development along the upper Tagus estuary features wide boulevards and glass-clad towers that create localized wind acceleration and heat reflection. The open riverside promenade benefits from estuary breezes, but the flat, exposed terrain and lack of mature tree canopy intensify solar heat gain during summer afternoons." },
        { name: 'Mouraria', slug: 'mouraria', lat: 38.7155, lon: -9.1350, group: 'Historic Center', description: "Mouraria clings to the steep northern slope of the Castle hill, where its tightly packed buildings and narrow alleys create a sheltered microclimate largely cut off from Tagus breezes. The north-facing aspect means less direct winter sun than neighboring Alfama, resulting in cooler, damper conditions during the wet season." },
        { name: 'Graça', slug: 'graca', lat: 38.7190, lon: -9.1310, group: 'Historic Center', description: "Graça sits atop one of Lisbon's highest hills at around 100m, fully exposed to prevailing northwest winds that make it one of the city's breeziest residential areas. The hilltop miradouros experience wind chill in winter but benefit from excellent natural ventilation that keeps summer heat islands minimal compared to the valleys below." },
        { name: 'Estrela', slug: 'estrela', lat: 38.7139, lon: -9.1580, group: 'Central West', description: "Estrela benefits from the substantial cooling effect of the Jardim da Estrela, one of Lisbon's largest parks, which creates a measurable green island effect reducing ambient temperatures by 2–3°C on summer days. Its elevated western position catches Atlantic air masses early, and the basilica's dome acts as a local wind deflector creating sheltered pockets on its leeward side." },
        { name: 'Campo de Ourique', slug: 'campo-de-ourique', lat: 38.7190, lon: -9.1650, group: 'Central West', description: "Campo de Ourique's grid layout on a gentle western-facing slope creates effective channeling of Atlantic breezes along its straight streets. The neighborhood's medium-density residential fabric with consistent 4–5 story buildings provides mutual shading while allowing better airflow than the cramped historic quarters to the east." },
        { name: 'Alcântara', slug: 'alcantara', lat: 38.7050, lon: -9.1780, group: 'Western Waterfront', description: "Alcântara sits in a low valley between the hills of Estrela and Ajuda, creating a natural drainage channel where cool nighttime air pools, resulting in Lisbon's most frequent valley fog occurrences. The neighborhood's industrial heritage of warehouses and rail infrastructure creates significant thermal mass that retains heat, contrasting with the river-cooled air just meters away at the dockside." },
        { name: 'Ajuda', slug: 'ajuda', lat: 38.7095, lon: -9.1920, group: 'Western Hills', description: "Ajuda's elevated position on the western hillside above the Tagus provides sweeping exposure to Atlantic weather systems arriving from the southwest, making it one of Lisbon's windiest and rainiest neighborhoods. The proximity of Monsanto Forest Park on its northern flank channels cooled, humidified air downslope, creating noticeably fresher conditions than the dense city center." },
        { name: 'Avenidas Novas', slug: 'avenidas-novas', lat: 38.7370, lon: -9.1470, group: 'North Central', description: "Avenidas Novas' broad Pombaline-inspired boulevards lined with mature plane trees create Lisbon's most pronounced urban canyon effect, trapping heat within the wide avenues while tree canopy provides essential shade. The flat terrain at the top of the Baixa valley means this district misses both hilltop winds and riverside breezes, creating a significant urban heat island during summer anticyclonic conditions." },
        { name: 'Benfica', slug: 'benfica', lat: 38.7520, lon: -9.2000, group: 'Northwest', description: "Benfica's inland position at the northwest edge of the city places it closer to the Monsanto Forest Park, whose 900-hectare canopy generates a substantial cooling effect on prevailing northwest winds passing over it. The neighborhood sits at a slightly higher elevation than central Lisbon and lacks river influence, leading to greater temperature extremes — hotter summer peaks and colder winter mornings." },
        { name: 'Marvila', slug: 'marvila', lat: 38.7420, lon: -9.1060, group: 'Eastern Riverside', description: "Marvila's former industrial riverside zone retains extensive impervious surfaces — warehouses, rail yards, and concrete — that create one of Lisbon's most intense localized heat islands. The flat eastern riverfront receives full afternoon sun reflected off the wide Tagus, though ongoing urban regeneration with new green corridors is beginning to moderate temperatures." },
        { name: 'Lumiar', slug: 'lumiar', lat: 38.7710, lon: -9.1620, group: 'Northern Suburbs', description: "Lumiar's position on Lisbon's northern plateau, away from the Tagus moderating influence, gives it the city's greatest diurnal temperature range — summer nights are notably cooler than downtown while afternoon peaks match or exceed riverside readings. The neighborhood's lower building density and proximity to extensive green spaces around the Lisbon University campus allow cold air to settle freely on calm winter nights." },
      ],
    },

]

export function getCity(slug: string): City | undefined {
  return CITIES.find((c) => c.slug === slug)
}

export function getDistrict(citySlug: string, districtSlug: string): District | undefined {
  return getCity(citySlug)?.districts.find((d) => d.slug === districtSlug)
}
